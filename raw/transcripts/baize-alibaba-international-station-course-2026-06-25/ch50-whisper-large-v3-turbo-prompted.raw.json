		},
		{
			"timestamps": {
				"from": "00:10:05,220",
				"to": "00:10:06,240"
			},
			"offsets": {
				"from": 605220,
				"to": 606240
			},
			"text": "这样的话"
		},
		{
			"timestamps": {
				"from": "00:10:06,240",
				"to": "00:10:09,060"
			},
			"offsets": {
				"from": 606240,
				"to": 609060
			},
			"text": "那么你做的事情就更加简单"
		},
