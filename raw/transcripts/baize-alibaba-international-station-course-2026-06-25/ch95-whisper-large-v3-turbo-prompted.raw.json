				"to": "00:01:23,340"
			},
			"offsets": {
				"from": 79140,
				"to": 83340
			},
			"text": "这样的话我们后期所做的标题就没有什么小问题了"
		},
		{
			"timestamps": {
				"from": "00:01:23,340",
				"to": "00:01:28,580"
			},
			"offsets": {
				"from": 83340,
				"to": 88580
			},
			"text": "首先第一个就是产品名称跟买家搜索词的相关性"
		},
		{
			"timestamps": {
				"from": "00:01:28,580",
				"to": "00:01:34,100"
			},
			"offsets": {
				"from": 88580,
				"to": 94100
			},
			"text": "它的相关性和关键词的顺序间隔大小是没有关系的"
		},
		{
			"timestamps": {
				"from": "00:01:34,100",
				"to": "00:01:40,480"
			},
			"offsets": {
				"from": 94100,
				"to": 100480
			},
			"text": "比如说文本的相关性如果买家用文费这个词搜索产品"
		},
		{
			"timestamps": {
				"from": "00:01:40,480",
