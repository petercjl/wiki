				"to": 267820
			},
			"text": "但是如果你增加了一个赛道,比如说你普通寻盘品你再做了, 然后再去发一些可交易寻盘品, 同时把这些产品打造起来"
		},
		{
			"timestamps": {
				"from": "00:04:27,820",
				"to": "00:04:40,880"
			},
			"offsets": {
				"from": 267820,
				"to": 280880
			},
			"text": "那么你就会发现原来流量的瓶颈在A这个线, 增长到A这个线, 然后你增加了一个寻盘可交易品, 就增加到了B这条, 跳花板这条流量线或寻盘线"
		},
		{
			"timestamps": {
				"from": "00:04:41,140",
				"to": "00:04:52,920"
			},
			"offsets": {
				"from": 281140,
				"to": 292920
			},
			"text": "所以说他就能够上升一个层级, 如果你在把店铺增加一个RTS产品赛到, 也就是说你店铺里面要发RTS产品, 并且打造这些产品"
		},
		{
			"timestamps": {
				"from": "00:04:52,920",
				"to": "00:05:00,340"
			},
			"offsets": {
				"from": 292920,
				"to": 300340
			},
			"text": "那么你这个流量层级可能就升到C层级, 也就是说流量, 整个店铺的总流量会更大"
		},
		{
			"timestamps": {
				"from": "00:05:00,340",
				"to": "00:05:10,580"
			},
			"offsets": {
				"from": 300340,
				"to": 310580
			},
			"text": "如果你再加上这个半托, 那么再增长到C这个流量, 所以说你看4个流量的用口, 能够给你整个店铺"
		},
		{
			"timestamps": {
				"from": "00:05:10,840",
				"to": "00:05:18,780"
			},
			"offsets": {
				"from": 310840,
				"to": 318780
			},
			"text": "进行一个综合的导流, 如果你仅仅是做定制赛道, 那么你获得的流量可能就是这一点点"
		},
		{
			"timestamps": {
				"from": "00:05:18,780",
				"to": "00:05:23,900"
			},
			"offsets": {
				"from": 318780,
				"to": 323900
			},
			"text": "如果你再增加许盘可教育品的流量, 那么你再增加一点点"
		},
		{
			"timestamps": {
				"from": "00:05:23,900",
				"to": "00:05:34,140"
			},
			"offsets": {
				"from": 323900,
				"to": 334140
			},
			"text": "如果你又把RTS做了, 再增加这边, 再把半托做了, 就相当于整个店铺的综合的总流量, 就会大大的提升了"
		},
		{
			"timestamps": {
				"from": "00:05:34,140",
				"to": "00:05:39,000"
			},
			"offsets": {
				"from": 334140,
				"to": 339000
			},
			"text": "这个是在店铺层级上面去努力"
		},
		{
			"timestamps": {
				"from": "00:05:39,260",
				"to": "00:05:42,340"
			},
			"offsets": {
				"from": 339260,
				"to": 342340
			},
			"text": "而不是在操作层上面去努力"
		},
		{
			"timestamps": {
				"from": "00:05:42,340",
				"to": "00:05:45,920"
			},
			"offsets": {
				"from": 342340,
				"to": 345920
			},
			"text": "有些时候你店铺的层已经固定了"
		},
		{
			"timestamps": {
				"from": "00:05:45,920",
				"to": "00:05:51,540"
			},
			"offsets": {
				"from": 345920,
				"to": 351540
			},
			"text": "你在细节上面无论你怎么操作他的天花板是非常明显的"
		},
		{
			"timestamps": {
				"from": "00:05:51,540",
				"to": "00:05:58,720"
			},
			"offsets": {
				"from": 351540,
				"to": 358720
			},
			"text": "如果你在这个细节操作上面提升不了店铺的整体的流量层级或寻盘的时候"
		},
		{
			"timestamps": {
				"from": "00:05:58,720",
				"to": "00:06:04,100"
			},
			"offsets": {
				"from": 358720,
				"to": 364100
			},
			"text": "你一定要往在上一层也就是店铺赛道层级思考"
		},
		{
			"timestamps": {
				"from": "00:06:04,100",
				"to": "00:06:06,660"
			},
			"offsets": {
				"from": 364100,
				"to": 366660
			},
			"text": "也就是从这四大赛道入口"
		},
		{
			"timestamps": {
				"from": "00:06:06,900",
				"to": "00:06:09,720"
			},
			"offsets": {
				"from": 366900,
				"to": 369720
			},
			"text": "去进行一个选择过充流量"
		},
		{
			"timestamps": {
				"from": "00:06:09,720",
				"to": "00:06:13,040"
			},
			"offsets": {
				"from": 369720,
				"to": 373040
			},
			"text": "比如说你原来是做普通群盘品的店铺"
		},
		{
			"timestamps": {
				"from": "00:06:13,040",
				"to": "00:06:15,860"
			},
			"offsets": {
				"from": 373040,
				"to": 375860
			},
			"text": "那么流量已经达到了一个峰值"
		},
		{
			"timestamps": {
				"from": "00:06:15,860",
				"to": "00:06:20,720"
			},
			"offsets": {
				"from": 375860,
				"to": 380720
			},
			"text": "你无论怎么操作都无法提升整个店铺的流量的时候"
		},
		{
			"timestamps": {
				"from": "00:06:20,720",
				"to": "00:06:22,260"
			},
			"offsets": {
				"from": 380720,
				"to": 382260
			},
			"text": "那么你要考虑一下"
		},
		{
			"timestamps": {
				"from": "00:06:22,260",
				"to": "00:06:25,840"
			},
			"offsets": {
				"from": 382260,
				"to": 385840
			},
			"text": "我是不是可以增加群盘可交易品这些产品"
		},
		{
			"timestamps": {
				"from": "00:06:25,840",
				"to": "00:06:28,140"
			},
			"offsets": {
				"from": 385840,
				"to": 388140
			},
			"text": "并且去打造一下这些产品"
		},
		{
			"timestamps": {
				"from": "00:06:28,140",
				"to": "00:06:31,980"
			},
			"offsets": {
				"from": 388140,
				"to": 391980
			},
			"text": "来提升我整个店铺层级的流量"
		},
		{
			"timestamps": {
				"from": "00:06:31,980",
				"to": "00:06:35,580"
			},
			"offsets": {
				"from": 391980,
				"to": 395580
			},
			"text": "如果你这个也做到了比较好"
		},
		{
			"timestamps": {
				"from": "00:06:36,340",
				"to": "00:06:39,920"
			},
			"offsets": {
				"from": 396340,
				"to": 399920
			},
			"text": "还缺流量是不是再加一个赛道是不是再加一个赛道"
		},
		{
			"timestamps": {
				"from": "00:06:39,920",
				"to": "00:06:44,780"
			},
			"offsets": {
				"from": 399920,
				"to": 404780
			},
			"text": "这样的话那么我们整个店铺的总流量就非常大了"
		},
		{
			"timestamps": {
				"from": "00:06:44,780",
				"to": "00:06:47,100"
			},
			"offsets": {
				"from": 404780,
				"to": 407100
			},
			"text": "按照目前来看"
		},
		{
			"timestamps": {
				"from": "00:06:47,100",
				"to": "00:06:49,140"
			},
			"offsets": {
				"from": 407100,
				"to": 409140
			},
			"text": "我们平台上面"
		},
		{
			"timestamps": {
				"from": "00:06:49,140",
				"to": "00:06:54,520"
			},
			"offsets": {
				"from": 409140,
				"to": 414520
			},
			"text": "如果你只做定制赛道比如说就是普通寻盘品和寻盘可交易品"
		},
		{
			"timestamps": {
				"from": "00:06:54,520",
				"to": "00:07:01,180"
			},
			"offsets": {
				"from": 414520,
				"to": 421180
			},
			"text": "这两种类型的产品那么他的流量占比可能在30%到40%"
		},
		{
			"timestamps": {
				"from": "00:07:01,180",
				"to": "00:07:05,020"
			},
			"offsets": {
				"from": 421180,
				"to": 425020
			},
			"text": "那么如果你的店铺只做快速交易"
		},
		{
			"timestamps": {
				"from": "00:07:05,260",
				"to": "00:07:09,860"
			},
			"offsets": {
				"from": 425260,
				"to": 429860
			},
			"text": "搭贴时半拖款你的流量可能占比达到60%到70%"
		},
		{
			"timestamps": {
				"from": "00:07:09,860",
				"to": "00:07:12,940"
			},
			"offsets": {
				"from": 429860,
				"to": 432940
			},
			"text": "所以你要想一下你的产品"
		},
		{
			"timestamps": {
				"from": "00:07:12,940",
				"to": "00:07:17,040"
			},
			"offsets": {
				"from": 432940,
				"to": 437040
			},
			"text": "你的公司优势和供应链的优势"
		},
		{
			"timestamps": {
				"from": "00:07:17,040",
				"to": "00:07:22,660"
			},
			"offsets": {
				"from": 437040,
				"to": 442660
			},
			"text": "适合选择12344个里面的哪几个"
		},
		{
			"timestamps": {
				"from": "00:07:22,660",
				"to": "00:07:24,720"
			},
			"offsets": {
				"from": 442660,
				"to": 444720
			},
			"text": "来进行展开工作"
		},
		{
			"timestamps": {
				"from": "00:07:24,720",
				"to": "00:07:28,040"
			},
			"offsets": {
				"from": 444720,
				"to": 448040
			},
			"text": "这是决定让你流量天"
		},
		{
			"timestamps": {
				"from": "00:07:28,040",
				"to": "00:07:32,140"
			},
			"offsets": {
				"from": 448040,
				"to": 452140
			},
			"text": "店铺流量天花板的一个关键的层级选择"
		},
		{
			"timestamps": {
				"from": "00:07:32,140",
				"to": "00:07:34,180"
			},
			"offsets": {
				"from": 452140,
				"to": 454180
			},
			"text": "所以这个你要自己去评估"
		},
		{
			"timestamps": {
				"from": "00:07:34,180",
				"to": "00:07:39,040"
			},
			"offsets": {
				"from": 454180,
				"to": 459040
			},
			"text": "而不仅仅只是在那个细节上去操作"
		},
		{
			"timestamps": {
				"from": "00:07:39,040",
				"to": "00:07:44,160"
			},
			"offsets": {
				"from": 459040,
				"to": 464160
			},
			"text": "你要从更大的范围去拉升整个店铺的流量和循环"
		},
		{
			"timestamps": {
				"from": "00:07:44,160",
				"to": "00:07:47,500"
			},
			"offsets": {
				"from": 464160,
				"to": 467500
			},
			"text": "那么这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:07:47,500",
				"to": "00:07:49,280"
			},
			"offsets": {
				"from": 467500,
				"to": 469280
			},
			"text": "下节课我们再见"
		}
	]
}
