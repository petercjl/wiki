				"to": "00:03:38,680"
			},
			"offsets": {
				"from": 216640,
				"to": 218680
			},
			"text": "那么最后一个我们来"
		},
		{
			"timestamps": {
				"from": "00:03:38,680",
				"to": "00:03:40,480"
			},
			"offsets": {
				"from": 218680,
				"to": 220480
			},
			"text": "理解一个概念的坑"
		},
		{
			"timestamps": {
				"from": "00:03:40,480",
				"to": "00:03:42,520"
			},
			"offsets": {
				"from": 220480,
				"to": 222520
			},
			"text": "首先零星和"
		},
		{
			"timestamps": {
				"from": "00:03:42,520",
				"to": "00:03:44,320"
			},
			"offsets": {
				"from": 222520,
				"to": 224320
			},
			"text": "一星到两星的"
		},
		{
			"timestamps": {
				"from": "00:03:44,320",
				"to": "00:03:45,860"
			},
			"offsets": {
				"from": 224320,
				"to": 225860
			},
			"text": "流量层级差距"
		},
		{
			"timestamps": {
				"from": "00:03:45,860",
				"to": "00:03:48,160"
			},
			"offsets": {
				"from": 225860,
				"to": 228160
			},
			"text": "很大, 也就是你店铺可能是零星"
		},
		{
			"timestamps": {
				"from": "00:03:48,160",
				"to": "00:03:49,960"
			},
			"offsets": {
				"from": 228160,
				"to": 229960
			},
			"text": "跟一星两星的"
		},
		{
			"timestamps": {
				"from": "00:03:49,960",
				"to": "00:03:51,480"
			},
			"offsets": {
				"from": 229960,
				"to": 231480
			},
			"text": "流量的差距"
		},
		{
			"timestamps": {
				"from": "00:03:51,740",
				"to": "00:03:57,120"
			},
			"offsets": {
				"from": 231740,
				"to": 237120
			},
			"text": "是比较大的, 一星跟两星和三星到五星的流量层级的差距"
		},
		{
			"timestamps": {
				"from": "00:03:57,120",
				"to": "00:04:00,700"
			},
			"offsets": {
				"from": 237120,
				"to": 240700
			},
			"text": "也是很大的, 也就是你这里一到两星的"
		},
		{
			"timestamps": {
				"from": "00:04:00,700",
				"to": "00:04:03,520"
			},
			"offsets": {
				"from": 240700,
				"to": 243520
			},
			"text": "那个流量区别不是很大"
		},
		{
			"timestamps": {
				"from": "00:04:03,520",
				"to": "00:04:07,860"
			},
			"offsets": {
				"from": 243520,
				"to": 247860
			},
			"text": "一到两星跟三到五星的区别就很大"
		},
		{
			"timestamps": {
				"from": "00:04:07,860",
				"to": "00:04:10,180"
			},
			"offsets": {
				"from": 247860,
				"to": 250180
			},
			"text": "所以说如果你在"
		},
		{
			"timestamps": {
				"from": "00:04:10,180",
				"to": "00:04:12,980"
			},
			"offsets": {
				"from": 250180,
				"to": 252980
			},
			"text": "两星的时候那么你要尽量"
		},
		{
			"timestamps": {
				"from": "00:04:12,980",
				"to": "00:04:17,340"
			},
			"offsets": {
				"from": 252980,
				"to": 257340
			},
			"text": "跃迁到三星那么这个是一个流量层级的变化"
		},
		{
			"timestamps": {
				"from": "00:04:17,340",
				"to": "00:04:21,180"
			},
			"offsets": {
				"from": 257340,
				"to": 261180
			},
			"text": "如果你在零星的时候你至少要能拿到一星"
		},
		{
			"timestamps": {
				"from": "00:04:21,440",
				"to": "00:04:22,980"
			},
			"offsets": {
				"from": 261440,
				"to": 262980
			},
			"text": "就这两个零界点"
		},
		{
			"timestamps": {
				"from": "00:04:22,980",
				"to": "00:04:25,280"
			},
			"offsets": {
				"from": 262980,
				"to": 265280
			},
			"text": "非常的关键, 按照这种"
		},
		{
			"timestamps": {
				"from": "00:04:25,280",
				"to": "00:04:26,040"
			},
			"offsets": {
				"from": 265280,
				"to": 266040
			},
			"text": "实录去"
		},
		{
			"timestamps": {
				"from": "00:04:26,040",
				"to": "00:04:29,380"
			},
			"offsets": {
				"from": 266040,
				"to": 269380
			},
			"text": "提升你店铺的星级, 那么你的流量层级"
		},
		{
			"timestamps": {
				"from": "00:04:29,380",
				"to": "00:04:31,420"
			},
			"offsets": {
				"from": 269380,
				"to": 271420
			},
			"text": "至少能够上一个层级"
		},
		{
			"timestamps": {
				"from": "00:04:31,420",
				"to": "00:04:33,980"
			},
			"offsets": {
				"from": 271420,
				"to": 273980
			},
			"text": "最后一个就是一定要花点钱"
		},
		{
			"timestamps": {
				"from": "00:04:33,980",
				"to": "00:04:35,260"
			},
			"offsets": {
				"from": 273980,
				"to": 275260
			},
			"text": "也不要零星"
		},
		{
			"timestamps": {
				"from": "00:04:35,260",
				"to": "00:04:36,540"
			},
			"offsets": {
				"from": 275260,
				"to": 276540
			},
			"text": "我刚才说的这个"
		},
		{
			"timestamps": {
				"from": "00:04:36,540",
				"to": "00:04:38,080"
			},
			"offsets": {
				"from": 276540,
				"to": 278080
			},
			"text": "你要花点钱也不要"
		},
		{
			"timestamps": {
				"from": "00:04:38,080",
				"to": "00:04:39,360"
			},
			"offsets": {
				"from": 278080,
				"to": 279360
			},
			"text": "让它是零星"
		},
		{
			"timestamps": {
				"from": "00:04:39,360",
				"to": "00:04:42,940"
			},
			"offsets": {
				"from": 279360,
				"to": 282940
			},
			"text": "否则你的直动车成本很高, 也就是你这里的"
		},
		{
			"timestamps": {
				"from": "00:04:42,940",
				"to": "00:04:44,480"
			},
			"offsets": {
				"from": 282940,
				"to": 284480
			},
			"text": "班单的手续费"
		},
		{
			"timestamps": {
				"from": "00:04:44,480",
				"to": "00:04:46,780"
			},
			"offsets": {
				"from": 284480,
				"to": 286780
			},
			"text": "远远低于你这个直动车的成本"
		},
		{
			"timestamps": {
				"from": "00:04:46,780",
				"to": "00:04:49,340"
			},
			"offsets": {
				"from": 286780,
				"to": 289340
			},
			"text": "所以我们要去自己去衡量"
		},
		{
			"timestamps": {
				"from": "00:04:49,600",
				"to": "00:04:51,400"
			},
			"offsets": {
				"from": 289600,
				"to": 291400
			},
			"text": "你是要用手续费去"
		},
		{
			"timestamps": {
				"from": "00:04:51,400",
				"to": "00:04:52,680"
			},
			"offsets": {
				"from": 291400,
				"to": 292680
			},
			"text": "提升你的"
		},
		{
			"timestamps": {
				"from": "00:04:52,680",
				"to": "00:04:55,240"
			},
			"offsets": {
				"from": 292680,
				"to": 295240
			},
			"text": "交易力呢, 还是单独靠"
		},
		{
			"timestamps": {
				"from": "00:04:55,240",
				"to": "00:04:57,020"
			},
			"offsets": {
				"from": 295240,
				"to": 297020
			},
			"text": "自动车成本去"
		},
		{
			"timestamps": {
				"from": "00:04:57,020",
				"to": "00:04:58,560"
			},
			"offsets": {
				"from": 297020,
				"to": 298560
			},
			"text": "提升你的交易力呢"
		},
		{
			"timestamps": {
				"from": "00:04:58,560",
				"to": "00:05:00,600"
			},
			"offsets": {
				"from": 298560,
				"to": 300600
			},
			"text": "如果用手续费"
		},
		{
			"timestamps": {
				"from": "00:05:00,600",
				"to": "00:05:04,200"
			},
			"offsets": {
				"from": 300600,
				"to": 304200
			},
			"text": "的成本肯定是会比你自动车的成本更低的"
		},
		{
			"timestamps": {
				"from": "00:05:04,200",
				"to": "00:05:05,980"
			},
			"offsets": {
				"from": 304200,
				"to": 305980
			},
			"text": "所以一定要想办法"
		},
		{
			"timestamps": {
				"from": "00:05:05,980",
				"to": "00:05:07,260"
			},
			"offsets": {
				"from": 305980,
				"to": 307260
			},
			"text": "去做好"
		},
		{
			"timestamps": {
				"from": "00:05:07,260",
				"to": "00:05:08,540"
			},
			"offsets": {
				"from": 307260,
				"to": 308540
			},
			"text": "正确的选择"
		},
		{
			"timestamps": {
				"from": "00:05:08,540",
				"to": "00:05:09,560"
			},
			"offsets": {
				"from": 308540,
				"to": 309560
			},
			"text": "然后去"
		},
		{
			"timestamps": {
				"from": "00:05:09,560",
				"to": "00:05:11,100"
			},
			"offsets": {
				"from": 309560,
				"to": 311100
			},
			"text": "针对性的提升"
		},
		{
			"timestamps": {
				"from": "00:05:11,360",
				"to": "00:05:13,160"
			},
			"offsets": {
				"from": 311360,
				"to": 313160
			},
			"text": "那么我们这个交易力"
		},
		{
			"timestamps": {
				"from": "00:05:13,160",
				"to": "00:05:14,440"
			},
			"offsets": {
				"from": 313160,
				"to": 314440
			},
			"text": "就能够在"
		},
		{
			"timestamps": {
				"from": "00:05:14,440",
				"to": "00:05:16,220"
			},
			"offsets": {
				"from": 314440,
				"to": 316220
			},
			"text": "具体的时间内"
		},
		{
			"timestamps": {
				"from": "00:05:16,220",
				"to": "00:05:17,500"
			},
			"offsets": {
				"from": 316220,
				"to": 317500
			},
			"text": "完成他的目标"
		},
		{
			"timestamps": {
				"from": "00:05:17,500",
				"to": "00:05:18,520"
			},
			"offsets": {
				"from": 317500,
				"to": 318520
			},
			"text": "就能够"
		},
		{
			"timestamps": {
				"from": "00:05:18,520",
				"to": "00:05:21,080"
			},
			"offsets": {
				"from": 318520,
				"to": 321080
			},
			"text": "让我们的电货的星级更高"
		},
		{
			"timestamps": {
				"from": "00:05:21,080",
				"to": "00:05:22,620"
			},
			"offsets": {
				"from": 321080,
				"to": 322620
			},
			"text": "获取更多的流量"
		},
		{
			"timestamps": {
				"from": "00:05:22,620",
				"to": "00:05:23,400"
			},
			"offsets": {
				"from": 322620,
				"to": 323400
			},
			"text": "好了"
		},
		{
			"timestamps": {
				"from": "00:05:23,400",
				"to": "00:05:25,440"
			},
			"offsets": {
				"from": 323400,
				"to": 325440
			},
			"text": "这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:05:25,440",
				"to": "00:05:26,200"
			},
			"offsets": {
				"from": 325440,
				"to": 326200
			},
			"text": "下节课"
		},
		{
			"timestamps": {
				"from": "00:05:26,200",
				"to": "00:05:27,240"
			},
			"offsets": {
				"from": 326200,
				"to": 327240
			},
			"text": "我们再见"
		}
	]
}
