				"to": 169860
			},
			"text": "进行一个测试就可以了"
		},
		{
			"timestamps": {
				"from": "00:02:49,860",
				"to": "00:02:50,780"
			},
			"offsets": {
				"from": 169860,
				"to": 170780
			},
			"text": "第二种情况就是"
		},
		{
			"timestamps": {
				"from": "00:02:50,780",
				"to": "00:02:54,580"
			},
			"offsets": {
				"from": 170780,
				"to": 174580
			},
			"text": "你的产品的款式跟访客国家不匹配的时候"
		},
		{
			"timestamps": {
				"from": "00:02:54,580",
				"to": "00:02:57,140"
			},
			"offsets": {
				"from": 174580,
				"to": 177140
			},
			"text": "那么你这个爆款产品来的寻盘"
		},
		{
			"timestamps": {
				"from": "00:02:57,140",
				"to": "00:02:59,540"
			},
			"offsets": {
				"from": 177140,
				"to": 179540
			},
			"text": "通常来说质量都是非常差的"
		},
		{
			"timestamps": {
				"from": "00:02:59,540",
				"to": "00:03:02,720"
			},
			"offsets": {
				"from": 179540,
				"to": 182720
			},
			"text": "首先我们要分析它的款式和国家的准确性"
		},
		{
			"timestamps": {
				"from": "00:03:02,720",
				"to": "00:03:08,980"
			},
			"offsets": {
				"from": 182720,
				"to": 188980
			},
			"text": "比如说你要去参考一下市场热销款和目标国家偏好的款式"
		},
		{
			"timestamps": {
				"from": "00:03:08,980",
				"to": "00:03:11,440"
			},
			"offsets": {
				"from": 188980,
				"to": 191440
			},
			"text": "特别是这个目标国家偏好的款式"
		},
		{
			"timestamps": {
				"from": "00:03:11,440",
				"to": "00:03:13,900"
			},
			"offsets": {
				"from": 191440,
				"to": 193900
			},
			"text": "这个款式如果跟你们的差距很大的话"
		},
		{
			"timestamps": {
				"from": "00:03:13,900",
				"to": "00:03:17,160"
			},
			"offsets": {
				"from": 193900,
				"to": 197160
			},
			"text": "好 比如说你美国市场跟非洲市场"
		},
		{
			"timestamps": {
				"from": "00:03:17,160",
				"to": "00:03:21,160"
			},
			"offsets": {
				"from": 197160,
				"to": 201160
			},
			"text": "你的款式是更偏向于非洲市场的"
		},
		{
			"timestamps": {
				"from": "00:03:21,160",
				"to": "00:03:24,560"
			},
			"offsets": {
				"from": 201160,
				"to": 204560
			},
			"text": "那么这个时候就会有非常多的非洲的流量"
		},
		{
			"timestamps": {
				"from": "00:03:24,560",
				"to": "00:03:26,360"
			},
			"offsets": {
				"from": 204560,
				"to": 206360
			},
			"text": "美国的流量就会非常的少"
		},
		{
			"timestamps": {
				"from": "00:03:26,360",
				"to": "00:03:30,640"
			},
			"offsets": {
				"from": 206360,
				"to": 210640
			},
			"text": "但是呢你们本身这个产品A就是做美国的"
		},
		{
			"timestamps": {
				"from": "00:03:30,640",
				"to": "00:03:32,360"
			},
			"offsets": {
				"from": 210640,
				"to": 212360
			},
			"text": "来了很多非洲的"
		},
		{
			"timestamps": {
				"from": "00:03:32,360",
				"to": "00:03:36,120"
			},
			"offsets": {
				"from": 212360,
				"to": 216120
			},
			"text": "所以说这个款式一定要选对美国的偏好的款式"
		},
		{
			"timestamps": {
				"from": "00:03:36,120",
				"to": "00:03:37,940"
			},
			"offsets": {
				"from": 216120,
				"to": 217940
			},
			"text": "才是最佳的"
		},
		{
			"timestamps": {
				"from": "00:03:37,940",
				"to": "00:03:40,260"
			},
			"offsets": {
				"from": 217940,
				"to": 220260
			},
			"text": "你要去查看这些国家的精准度"
		},
		{
			"timestamps": {
				"from": "00:03:40,260",
				"to": "00:03:42,600"
			},
			"offsets": {
				"from": 220260,
				"to": 222600
			},
			"text": "是否符合我们的产品市场销售"
		},
		{
			"timestamps": {
				"from": "00:03:42,600",
				"to": "00:03:46,700"
			},
			"offsets": {
				"from": 222600,
				"to": 226700
			},
			"text": "比如说你之前的这款产品已经数据非常好了"
		},
		{
			"timestamps": {
				"from": "00:03:46,700",
				"to": "00:03:49,860"
			},
			"offsets": {
				"from": 226700,
				"to": 229860
			},
			"text": "那么你就按照我刚才说的款式的偏好去看一下"
		},
		{
			"timestamps": {
				"from": "00:03:49,860",
				"to": "00:03:51,880"
			},
			"offsets": {
				"from": 229860,
				"to": 231880
			},
			"text": "是否符合你们目标市场"
		},
		{
			"timestamps": {
				"from": "00:03:51,880",
				"to": "00:03:53,940"
			},
			"offsets": {
				"from": 231880,
				"to": 233940
			},
			"text": "这个国家的偏好就可以了"
		},
		{
			"timestamps": {
				"from": "00:03:53,940",
				"to": "00:03:55,340"
			},
			"offsets": {
				"from": 233940,
				"to": 235340
			},
			"text": "优化的方法的话"
		},
		{
			"timestamps": {
				"from": "00:03:55,340",
				"to": "00:03:58,240"
			},
			"offsets": {
				"from": 235340,
				"to": 238240
			},
			"text": "我们通过直动车去改变了它标签"
		},
		{
			"timestamps": {
				"from": "00:03:58,240",
				"to": "00:04:02,100"
			},
			"offsets": {
				"from": 238240,
				"to": 242100
			},
			"text": "比如说之前这个爆款产品都是非洲来的巡盘"
		},
		{
			"timestamps": {
				"from": "00:04:02,100",
				"to": "00:04:03,540"
			},
			"offsets": {
				"from": 242100,
				"to": 243540
			},
			"text": "非洲点击的嘛"
		},
		{
			"timestamps": {
				"from": "00:04:03,540",
				"to": "00:04:06,480"
			},
			"offsets": {
				"from": 243540,
				"to": 246480
			},
			"text": "我们想要美国的銀盘跟美国的点击"
		},
		{
			"timestamps": {
				"from": "00:04:06,480",
				"to": "00:04:10,040"
			},
			"offsets": {
				"from": 246480,
				"to": 250040
			},
			"text": "那么这个时候我们通过直动车去推广这个爆品"
		},
		{
			"timestamps": {
				"from": "00:04:10,040",
				"to": "00:04:13,060"
			},
			"offsets": {
				"from": 250040,
				"to": 253060
			},
			"text": "把点击量积累在国家美国上面"
		},
		{
			"timestamps": {
				"from": "00:04:13,060",
				"to": "00:04:14,820"
			},
			"offsets": {
				"from": 253060,
				"to": 254820
			},
			"text": "持续的积累一段时间"
		},
		{
			"timestamps": {
				"from": "00:04:14,820",
				"to": "00:04:19,280"
			},
			"offsets": {
				"from": 254820,
				"to": 259280
			},
			"text": "就有可能把我们爆款的产品的一个国家的标签扭转"
		},
		{
			"timestamps": {
				"from": "00:04:19,280",
				"to": "00:04:23,440"
			},
			"offsets": {
				"from": 259280,
				"to": 263440
			},
			"text": "那么后期系统给我们推荐的流量就会更加的精准"
		},
		{
			"timestamps": {
				"from": "00:04:23,440",
				"to": "00:04:27,400"
			},
			"offsets": {
				"from": 263440,
				"to": 267400
			},
			"text": "第二个就是我们要考虑更换与国家相符"
		},
		{
			"timestamps": {
				"from": "00:04:27,400",
				"to": "00:04:32,420"
			},
			"offsets": {
				"from": 267400,
				"to": 272420
			},
			"text": "且与目标国家相符的产品主图或者是产品相应页"
		},
		{
			"timestamps": {
				"from": "00:04:32,420",
				"to": "00:04:34,900"
			},
			"offsets": {
				"from": 272420,
				"to": 274900
			},
			"text": "比如说你这个是A爆款"
		},
		{
			"timestamps": {
				"from": "00:04:34,900",
				"to": "00:04:36,680"
			},
			"offsets": {
				"from": 274900,
				"to": 276680
			},
			"text": "那都是来自非洲的是吧"
		},
		{
			"timestamps": {
				"from": "00:04:36,680",
				"to": "00:04:38,360"
			},
			"offsets": {
				"from": 276680,
				"to": 278360
			},
			"text": "这个非洲编号的"
		},
		{
			"timestamps": {
				"from": "00:04:38,360",
				"to": "00:04:42,840"
			},
			"offsets": {
				"from": 278360,
				"to": 282840
			},
			"text": "那么B这款产品跟A这款产品是相似的"
		},
		{
			"timestamps": {
				"from": "00:04:42,840",
				"to": "00:04:46,660"
			},
			"offsets": {
				"from": 282840,
				"to": 286660
			},
			"text": "或者是说同样标题都可以描述A产品或B产品"
		},
		{
			"timestamps": {
				"from": "00:04:46,660",
				"to": "00:04:50,960"
			},
			"offsets": {
				"from": 286660,
				"to": 290960
			},
			"text": "但是B产品更倾向于美国这个国家的风格款式"
		},
		{
			"timestamps": {
				"from": "00:04:50,960",
				"to": "00:04:56,520"
			},
			"offsets": {
				"from": 290960,
				"to": 296520
			},
			"text": "那么这个时候我们就把A这个爆款产品的主图换成B产品的主图"
		},
		{
			"timestamps": {
				"from": "00:04:56,520",
				"to": "00:04:59,000"
			},
			"offsets": {
				"from": 296520,
				"to": 299000
			},
			"text": "以及在详情页里面做一定的调整"
		},
		{
			"timestamps": {
				"from": "00:04:59,000",
				"to": "00:05:01,480"
			},
			"offsets": {
				"from": 299000,
				"to": 301480
			},
			"text": "调整成为B这款产品"
		},
		{
			"timestamps": {
				"from": "00:05:01,480",
				"to": "00:05:05,640"
			},
			"offsets": {
				"from": 301480,
				"to": 305640
			},
			"text": "当然这个方法容易会导致你流量下降的"
		},
		{
			"timestamps": {
				"from": "00:05:05,640",
				"to": "00:05:07,620"
			},
			"offsets": {
				"from": 305640,
				"to": 307620
			},
			"text": "所以说这个方法谨慎使用"
		},
		{
			"timestamps": {
				"from": "00:05:07,620",
				"to": "00:05:10,960"
			},
			"offsets": {
				"from": 307620,
				"to": 310960
			},
			"text": "除非你已经被逼到没办法"
		},
		{
			"timestamps": {
				"from": "00:05:10,960",
				"to": "00:05:13,940"
			},
			"offsets": {
				"from": 310960,
				"to": 313940
			},
			"text": "或者是说老板跟业务反感太严重"
		},
		{
			"timestamps": {
				"from": "00:05:13,940",
				"to": "00:05:17,000"
			},
			"offsets": {
				"from": 313940,
				"to": 317000
			},
			"text": "那么这个时候我们才会考虑换款式"
		},
		{
			"timestamps": {
				"from": "00:05:17,000",
				"to": "00:05:19,940"
			},
			"offsets": {
				"from": 317000,
				"to": 319940
			},
			"text": "三个就是价格起定量运费详情页"
		},
		{
			"timestamps": {
				"from": "00:05:19,940",
				"to": "00:05:24,040"
			},
			"offsets": {
				"from": 319940,
				"to": 324040
			},
			"text": "这些都会影响到你的目标人群的转化"
		},
		{
			"timestamps": {
				"from": "00:05:24,040",
				"to": "00:05:28,960"
			},
			"offsets": {
				"from": 324040,
				"to": 328960
			},
			"text": "因为不同的国家他偏好的价格起定量运费和详情页"
		},
		{
			"timestamps": {
				"from": "00:05:28,960",
				"to": "00:05:31,200"
			},
			"offsets": {
				"from": 328960,
				"to": 331200
			},
			"text": "他能够接受的程度都是不一样的"
		},
		{
			"timestamps": {
				"from": "00:05:31,200",
				"to": "00:05:35,600"
			},
			"offsets": {
				"from": 331200,
				"to": 335600
			},
			"text": "那么这个时候我们要去分析一下同行爆款产品的价格起定量"
		},
		{
			"timestamps": {
				"from": "00:05:35,600",
				"to": "00:05:40,200"
			},
			"offsets": {
				"from": 335600,
				"to": 340200
			},
			"text": "尽量的参考他们的价格去针对性的优化"
		},
		{
			"timestamps": {
				"from": "00:05:40,200",
				"to": "00:05:43,900"
			},
			"offsets": {
				"from": 340200,
				"to": 343900
			},
			"text": "开始的时候我们不建议是采用低价去引入"
		},
		{
			"timestamps": {
				"from": "00:05:43,900",
				"to": "00:05:48,880"
			},
			"offsets": {
				"from": 343900,
				"to": 348880
			},
			"text": "因为你前期可能这个爆款因为你用了太低的价格去引流"
		},
		{
			"timestamps": {
				"from": "00:05:48,880",
				"to": "00:05:54,120"
			},
			"offsets": {
				"from": 348880,
				"to": 354120
			},
			"text": "导致很多人就是因为你价格低起定量低才来找你寻价的"
		},
		{
			"timestamps": {
				"from": "00:05:54,120",
				"to": "00:05:56,660"
			},
			"offsets": {
				"from": 354120,
				"to": 356660
			},
			"text": "所以说就会显示你寻盘很多"
		},
		{
			"timestamps": {
				"from": "00:05:56,660",
				"to": "00:06:00,820"
			},
			"offsets": {
				"from": 356660,
				"to": 360820
			},
			"text": "但实际上只要你把真实的价格起定量跟客户聊天"
		},
		{
			"timestamps": {
				"from": "00:06:00,820",
				"to": "00:06:03,380"
			},
			"offsets": {
				"from": 360820,
				"to": 363380
			},
			"text": "那么他就直接就不回复这种情况"
		},
		{
			"timestamps": {
				"from": "00:06:03,380",
				"to": "00:06:08,940"
			},
			"offsets": {
				"from": 363380,
				"to": 368940
			},
			"text": "所以你的价格我建议尽量的跟你的实际的价格相差不大"
		},
		{
			"timestamps": {
				"from": "00:06:08,940",
				"to": "00:06:11,640"
			},
			"offsets": {
				"from": 368940,
				"to": 371640
			},
			"text": "也就是可以比实际的低一点点"
		},
		{
			"timestamps": {
				"from": "00:06:11,640",
				"to": "00:06:13,880"
			},
			"offsets": {
				"from": 371640,
				"to": 373880
			},
			"text": "但是不要低的太离谱"
		},
		{
			"timestamps": {
				"from": "00:06:13,900",
				"to": "00:06:17,340"
			},
			"offsets": {
				"from": 373900,
				"to": 377340
			},
			"text": "这样才能够吸引到更加精准的买家"
		},
		{
			"timestamps": {
				"from": "00:06:17,340",
				"to": "00:06:19,940"
			},
			"offsets": {
				"from": 377340,
				"to": 379940
			},
			"text": "这样的质量寻盘更加好一点"
		},
		{
			"timestamps": {
				"from": "00:06:19,940",
				"to": "00:06:21,900"
			},
			"offsets": {
				"from": 379940,
				"to": 381900
			},
			"text": "这里这个板块一定要注意点"
		},
		{
			"timestamps": {
				"from": "00:06:21,900",
				"to": "00:06:26,160"
			},
			"offsets": {
				"from": 381900,
				"to": 386160
			},
			"text": "如果是你做RTS的话按照实际的价格折扣优惠"
		},
		{
			"timestamps": {
				"from": "00:06:26,160",
				"to": "00:06:30,880"
			},
			"offsets": {
				"from": 386160,
				"to": 390880
			},
			"text": "这些作为一定的营销来吸引一下你的真正的目标客户"
		},
		{
			"timestamps": {
				"from": "00:06:30,880",
				"to": "00:06:34,880"
			},
			"offsets": {
				"from": 390880,
				"to": 394880
			},
			"text": "第四个板块呢就是业务的话数还有客户的反馈"
		},
		{
			"timestamps": {
				"from": "00:06:34,880",
				"to": "00:06:48,840"
			},
			"offsets": {
				"from": 394880,
				"to": 408840
			},
			"text": "比如说业务反馈说寻盘很差那到底怎么样差法要给出一个标准或者是说你要列出他差的一个数据或者是指标啊比如说你为什么差寻盘不回复的问题吗"
		},
		{
			"timestamps": {
				"from": "00:06:48,840",
				"to": "00:06:58,840"
			},
			"offsets": {
				"from": 408840,
				"to": 418840
			},
			"text": "或者是说回复了你自己聊天发的话数或者是说跟人聊的牛头不对马嘴这是不是也是业务话数的问题"
		},
		{
			"timestamps": {
				"from": "00:06:58,840",
				"to": "00:07:03,280"
			},
			"offsets": {
				"from": 418840,
				"to": 423280
			},
			"text": "另外一种可能新注册的买家太多L0的太多这也是一种情况"
		},
		{
			"timestamps": {
				"from": "00:07:03,280",
				"to": "00:07:08,280"
			},
			"offsets": {
				"from": 423280,
				"to": 428280
			},
			"text": "第四种情况可能就是来的国家的寻盘都不是我们想要的国家的寻盘"
		},
		{
			"timestamps": {
				"from": "00:07:08,280",
				"to": "00:07:14,280"
			},
			"offsets": {
				"from": 428280,
				"to": 434280
			},
			"text": "所以说这也是导致你寻盘质量差这些都是会导致订单量少的原因"
		},
		{
			"timestamps": {
				"from": "00:07:14,280",
				"to": "00:07:22,280"
			},
			"offsets": {
				"from": 434280,
				"to": 442280
			},
			"text": "所以如果订单少不单单是寻盘质量差的问题也有可能是业务话数的问题"
		},
		{
			"timestamps": {
				"from": "00:07:22,280",
				"to": "00:07:27,280"
			},
			"offsets": {
				"from": 442280,
				"to": 447280
			},
			"text": "或者是说他本身对这个产品的迫切需求的问题"
		},
		{
			"timestamps": {
				"from": "00:07:27,280",
				"to": "00:07:32,280"
			},
			"offsets": {
				"from": 447280,
				"to": 452280
			},
			"text": "比如说有些产品是季节性的现在不是当下最需求的时候"
		},
		{
			"timestamps": {
				"from": "00:07:32,280",
				"to": "00:07:36,280"
			},
			"offsets": {
				"from": 452280,
				"to": 456280
			},
			"text": "那么这个时候可能许蛮多但是成交定量少这是正常的"
		},
		{
			"timestamps": {
				"from": "00:07:36,280",
				"to": "00:07:41,280"
			},
			"offsets": {
				"from": 456280,
				"to": 461280
			},
			"text": "但是过了某段时间现在是这款产品最好的销售季节"
		},
		{
			"timestamps": {
				"from": "00:07:41,280",
				"to": "00:07:48,280"
			},
			"offsets": {
				"from": 461280,
				"to": 468280
			},
			"text": "如果是还不成交的话这个可能就是我们引流的时候把这些不精准的流量引进来导致的"
		},
		{
			"timestamps": {
				"from": "00:07:48,280",
				"to": "00:07:55,280"
			},
			"offsets": {
				"from": 468280,
				"to": 475280
			},
			"text": "一定要去多分析从运营维度和业务维度同时去分析就可以了"
		},
		{
			"timestamps": {
				"from": "00:07:55,280",
				"to": "00:07:58,280"
			},
			"offsets": {
				"from": 475280,
				"to": 478280
			},
			"text": "比如说我们在后台看一下业务聊天的内容"
		},
		{
			"timestamps": {
				"from": "00:07:58,280",
				"to": "00:08:04,280"
			},
			"offsets": {
				"from": 478280,
				"to": 484280
			},
			"text": "我们去看一下他聊天到底是不是很精准或者是说他聊天的方法是不是比较正确"
		},
		{
			"timestamps": {
				"from": "00:08:04,280",
				"to": "00:08:09,280"
			},
			"offsets": {
				"from": 484280,
				"to": 489280
			},
			"text": "这个时候我们跟业务经理老板等等这些直属的领导去沟通一下"
		},
		{
			"timestamps": {
				"from": "00:08:09,280",
				"to": "00:08:11,280"
			},
			"offsets": {
				"from": 489280,
				"to": 491280
			},
			"text": "反馈一下寻盘质量问题"
		},
		{
			"timestamps": {
				"from": "00:08:11,280",
				"to": "00:08:19,280"
			},
			"offsets": {
				"from": 491280,
				"to": 499280
			},
			"text": "沟通一下业务的需求以及重新定位一下我们说的优质寻盘是按照什么标准去判断的"
		},
		{
			"timestamps": {
				"from": "00:08:19,280",
				"to": "00:08:25,280"
			},
			"offsets": {
				"from": 499280,
				"to": 505280
			},
			"text": "我们一定要有一个相对清晰的一个判断标准或者是一个描述"
		},
		{
			"timestamps": {
				"from": "00:08:25,280",
				"to": "00:08:33,280"
			},
			"offsets": {
				"from": 505280,
				"to": 513280
			},
			"text": "如果你连标准跟描述都没有只是一句话说寻盘差那这种方式很难让你持续的去改进"
		},
		{
			"timestamps": {
				"from": "00:08:33,280",
				"to": "00:08:37,280"
			},
			"offsets": {
				"from": 513280,
				"to": 517280
			},
			"text": "一定要把框架跟标准逐渐的完善起来"
		},
		{
			"timestamps": {
				"from": "00:08:37,280",
				"to": "00:08:41,280"
			},
			"offsets": {
				"from": 517280,
				"to": 521280
			},
			"text": "比如说业务对产品跟运营对产品都不是很了解"
		},
		{
			"timestamps": {
				"from": "00:08:41,280",
				"to": "00:08:43,280"
			},
			"offsets": {
				"from": 521280,
				"to": 523280
			},
			"text": "那么这个时候专业度就没有体现出来"
		},
		{
			"timestamps": {
				"from": "00:08:43,280",
				"to": "00:08:46,280"
			},
			"offsets": {
				"from": 523280,
				"to": 526280
			},
			"text": "那么运营把握一广产品的话就不够精准"
		},
		{
			"timestamps": {
				"from": "00:08:46,280",
				"to": "00:08:49,280"
			},
			"offsets": {
				"from": 526280,
				"to": 529280
			},
			"text": "这个时候就要进行产品做业的培训"
		},
		{
			"timestamps": {
				"from": "00:08:49,280",
				"to": "00:08:52,280"
			},
			"offsets": {
				"from": 529280,
				"to": 532280
			},
			"text": "第二种情况就是业务可能它的话术"
		},
		{
			"timestamps": {
				"from": "00:08:52,280",
				"to": "00:08:55,280"
			},
			"offsets": {
				"from": 532280,
				"to": 535280
			},
			"text": "或者是说它聊天的方式可能就存在问题"
		},
		{
			"timestamps": {
				"from": "00:08:55,280",
				"to": "00:08:58,280"
			},
			"offsets": {
				"from": 535280,
				"to": 538280
			},
			"text": "这种情况我们就需要去对一些话术培训啊"
		},
		{
			"timestamps": {
				"from": "00:08:58,280",
				"to": "00:09:01,280"
			},
			"offsets": {
				"from": 538280,
				"to": 541280
			},
			"text": "或者是说提升一些它的销售技巧啊"
		},
		{
			"timestamps": {
				"from": "00:09:01,280",
				"to": "00:09:03,280"
			},
			"offsets": {
				"from": 541280,
				"to": 543280
			},
			"text": "这些板块都是可以提升的"
		},
		{
			"timestamps": {
				"from": "00:09:03,280",
				"to": "00:09:07,280"
			},
			"offsets": {
				"from": 543280,
				"to": 547280
			},
			"text": "所以寻盘差不是单单运营的问题"
		},
		{
			"timestamps": {
				"from": "00:09:07,280",
				"to": "00:09:12,280"
			},
			"offsets": {
				"from": 547280,
				"to": 552280
			},
			"text": "它是整个公司可能涉及到店铺的定位是否够清晰"
		},
		{
			"timestamps": {
				"from": "00:09:12,280",
				"to": "00:09:14,280"
			},
			"offsets": {
				"from": 552280,
				"to": 554280
			},
			"text": "运营目标是否清晰"
		},
		{
			"timestamps": {
				"from": "00:09:14,280",
				"to": "00:09:18,280"
			},
			"offsets": {
				"from": 554280,
				"to": 558280
			},
			"text": "业务的聊天技巧是否有足够的支撑"
		},
		{
			"timestamps": {
				"from": "00:09:18,280",
				"to": "00:09:21,280"
			},
			"offsets": {
				"from": 558280,
				"to": 561280
			},
			"text": "那么这样其实它是一个完整的链路的"
		},
		{
			"timestamps": {
				"from": "00:09:21,280",
				"to": "00:09:24,280"
			},
			"offsets": {
				"from": 561280,
				"to": 564280
			},
			"text": "所以每一个环节你要去做好了"
		},
		{
			"timestamps": {
				"from": "00:09:24,280",
				"to": "00:09:26,280"
			},
			"offsets": {
				"from": 564280,
				"to": 566280
			},
			"text": "才能够获得更好的效果"
		},
		{
			"timestamps": {
				"from": "00:09:26,280",
				"to": "00:09:28,280"
			},
			"offsets": {
				"from": 566280,
				"to": 568280
			},
			"text": "那么这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:09:28,280",
				"to": "00:09:32,280"
			},
			"offsets": {
				"from": 568280,
				"to": 572280
			},
			"text": "希望这个能够给你更多的一些新的思路和启发"
		},
		{
			"timestamps": {
				"from": "00:09:32,280",
				"to": "00:09:38,280"
			},
			"offsets": {
				"from": 572280,
				"to": 578280
			},
			"text": "去思考如何去优化和如何去与业务跟上下级去进行一个合作"
		},
		{
			"timestamps": {
				"from": "00:09:38,280",
				"to": "00:09:40,280"
			},
			"offsets": {
				"from": 578280,
				"to": 580280
			},
			"text": "这样我们的店铺产能会更好的发展"
		},
		{
			"timestamps": {
				"from": "00:09:40,280",
				"to": "00:09:41,040"
			},
			"offsets": {
				"from": 580280,
				"to": 581040
			},
			"text": "更好的发展"
		},
		{
			"timestamps": {
				"from": "00:09:41,040",
				"to": "00:09:42,920"
			},
			"offsets": {
				"from": 581040,
				"to": 582920
			},
			"text": "那么这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:09:42,920",
				"to": "00:09:44,080"
			},
			"offsets": {
				"from": 582920,
				"to": 584080
			},
			"text": "下节课我们再见"
		}
	]
}
