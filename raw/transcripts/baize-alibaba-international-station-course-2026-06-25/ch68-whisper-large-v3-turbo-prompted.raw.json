			"text": "有产品推荐"
		},
		{
			"timestamps": {
				"from": "00:02:59,940",
				"to": "00:03:04,420"
			},
			"offsets": {
				"from": 179940,
				"to": 184420
			},
			"text": "买家资付发布寻盘的一个列表都会有一些产品的推荐界面"
		},
		{
			"timestamps": {
				"from": "00:03:04,420",
				"to": "00:03:06,580"
			},
			"offsets": {
				"from": 184420,
				"to": 186580
			},
			"text": "这些都是推荐流量"
		},
		{
			"timestamps": {
				"from": "00:03:06,580",
				"to": "00:03:08,900"
			},
			"offsets": {
				"from": 186580,
				"to": 188900
			},
			"text": "所以这些板块一定要重视起来"
		},
		{
			"timestamps": {
				"from": "00:03:08,900",
				"to": "00:03:13,300"
			},
			"offsets": {
				"from": 188900,
				"to": 193300
			},
			"text": "你要知道整个平台哪里有流量可以导入你的店铺里面"
		},
		{
			"timestamps": {
				"from": "00:03:13,300",
				"to": "00:03:16,060"
			},
			"offsets": {
				"from": 193300,
				"to": 196060
			},
			"text": "那么你就更加清晰你要去做什么事情了"
		},
		{
			"timestamps": {
				"from": "00:03:16,060",
				"to": "00:03:18,760"
			},
			"offsets": {
				"from": 196060,
				"to": 198760
			},
			"text": "那么这个就是关于平台流量的结构"
		},
		{
			"timestamps": {
				"from": "00:03:18,760",
				"to": "00:03:23,020"
			},
			"offsets": {
				"from": 198760,
				"to": 203020
			},
			"text": "我们可以通过这个结构来找到我们流量增长的巨大"
		},
		{
			"timestamps": {
				"from": "00:03:23,020",
				"to": "00:03:26,920"
			},
			"offsets": {
				"from": 203020,
				"to": 206920
			},
			"text": "那么如何找到我们店铺里面需要增长的流量呢"
		},
		{
			"timestamps": {
				"from": "00:03:26,920",
				"to": "00:03:28,780"
			},
			"offsets": {
				"from": 206920,
				"to": 208780
			},
			"text": "比如说我们店铺里面"
		},
		{
			"timestamps": {
				"from": "00:03:28,780",
				"to": "00:03:32,200"
			},
			"offsets": {
				"from": 208780,
				"to": 212200
			},
			"text": "目前的自然流量跟付费流量的占比"
		},
		{
			"timestamps": {
				"from": "00:03:32,200",
				"to": "00:03:36,120"
			},
			"offsets": {
				"from": 212200,
				"to": 216120
			},
			"text": "比如说是付费流量占比80%"
		},
		{
			"timestamps": {
				"from": "00:03:36,120",
				"to": "00:03:38,440"
			},
			"offsets": {
				"from": 216120,
				"to": 218440
			},
			"text": "那自然流量可能占比20%"
		},
		{
			"timestamps": {
				"from": "00:03:38,440",
				"to": "00:03:42,640"
			},
			"offsets": {
				"from": 218440,
				"to": 222640
			},
			"text": "那么这种情况是不是我们要想办法提升我们的整体的自然流量"
		},
		{
			"timestamps": {
				"from": "00:03:42,640",
				"to": "00:03:45,480"
			},
			"offsets": {
				"from": 222640,
				"to": 225480
			},
			"text": "降低这个平台的一个付费流量"
		},
		{
			"timestamps": {
				"from": "00:03:45,480",
				"to": "00:03:49,480"
			},
			"offsets": {
				"from": 225480,
				"to": 229480
			},
			"text": "那么是不是才有可能降低我们的平台成本"
		},
		{
			"timestamps": {
				"from": "00:03:49,480",
				"to": "00:03:51,520"
			},
			"offsets": {
				"from": 229480,
				"to": 231520
			},
			"text": "和整个店铺的运营成本"
		},
		{
			"timestamps": {
				"from": "00:03:51,520",
				"to": "00:03:53,600"
			},
			"offsets": {
				"from": 231520,
				"to": 233600
			},
			"text": "这边增这边就会降"
		},
		{
			"timestamps": {
				"from": "00:03:53,600",
				"to": "00:03:56,600"
			},
			"offsets": {
				"from": 233600,
				"to": 236600
			},
			"text": "因为它加起来是等于百分百的"
		},
		{
			"timestamps": {
				"from": "00:03:56,600",
				"to": "00:04:00,100"
			},
			"offsets": {
				"from": 236600,
				"to": 240100
			},
			"text": "所以这个就是我们判断的一个标准跟依据"
		},
		{
			"timestamps": {
				"from": "00:04:00,100",
				"to": "00:04:03,120"
			},
			"offsets": {
				"from": 240100,
				"to": 243120
			},
			"text": "你要知道它是这么样的一个逻辑"
		},
		{
			"timestamps": {
				"from": "00:04:03,120",
				"to": "00:04:04,520"
			},
			"offsets": {
				"from": 243120,
				"to": 244520
			},
			"text": "是有公式计算的"
		},
		{
			"timestamps": {
				"from": "00:04:04,520",
				"to": "00:04:09,320"
			},
			"offsets": {
				"from": 244520,
				"to": 249320
			},
			"text": "所以你就会知道要做哪些维度去提升我们店铺就可以了"
		},
		{
			"timestamps": {
				"from": "00:04:09,320",
				"to": "00:04:14,800"
			},
			"offsets": {
				"from": 249320,
				"to": 254800
			},
			"text": "那么下一节课我们会详细讲解这些里面的一些重要的板块"
		},
		{
			"timestamps": {
				"from": "00:04:14,800",
				"to": "00:04:17,880"
			},
			"offsets": {
				"from": 254800,
				"to": 257880
			},
			"text": "我们只讲几个比较重要的板块"
		},
		{
			"timestamps": {
				"from": "00:04:17,880",
				"to": "00:04:22,520"
			},
			"offsets": {
				"from": 257880,
				"to": 262520
			},
			"text": "其他的那些板块你可以按照自己的思路去看就可以了"
		},
		{
			"timestamps": {
				"from": "00:04:22,520",
				"to": "00:04:23,960"
			},
			"offsets": {
				"from": 262520,
				"to": 263960
			},
			"text": "比如说这些我们就不讲了"
		},
		{
			"timestamps": {
				"from": "00:04:23,960",
				"to": "00:04:27,080"
			},
			"offsets": {
				"from": 263960,
				"to": 267080
			},
			"text": "你就可以去按照我的这个框架去学就可以了"
		},
		{
			"timestamps": {
				"from": "00:04:27,080",
				"to": "00:04:29,000"
			},
			"offsets": {
				"from": 267080,
				"to": 269000
			},
			"text": "那么这些我们之前也讲了"
		},
		{
			"timestamps": {
				"from": "00:04:29,000",
				"to": "00:04:31,600"
			},
			"offsets": {
				"from": 269000,
				"to": 271600
			},
			"text": "其实也没有必要去详细的讲解了"
		},
		{
			"timestamps": {
				"from": "00:04:31,600",
				"to": "00:04:35,440"
			},
			"offsets": {
				"from": 271600,
				"to": 275440
			},
			"text": "那么这一个板块在直通教板块也详细讲解了"
		},
		{
			"timestamps": {
				"from": "00:04:35,440",
				"to": "00:04:37,300"
			},
			"offsets": {
				"from": 275440,
				"to": 277300
			},
			"text": "这里就不展开来讲解了"
		},
		{
			"timestamps": {
				"from": "00:04:37,300",
				"to": "00:04:38,880"
			},
			"offsets": {
				"from": 277300,
				"to": 278880
			},
			"text": "这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:04:38,880",
				"to": "00:04:42,080"
			},
			"offsets": {
				"from": 278880,
