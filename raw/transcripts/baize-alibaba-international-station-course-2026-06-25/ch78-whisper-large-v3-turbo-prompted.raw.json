				"from": "00:03:09,480",
				"to": "00:03:13,440"
			},
			"offsets": {
				"from": 189480,
				"to": 193440
			},
			"text": "整个店铺就处于一个动态流量变化的状态"
		},
		{
			"timestamps": {
				"from": "00:03:13,440",
				"to": "00:03:15,880"
			},
			"offsets": {
				"from": 193440,
				"to": 195880
			},
			"text": "那么这样的店铺才会更加的健康"
		},
		{
			"timestamps": {
