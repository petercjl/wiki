				"to": 702780
			},
			"text": "前期可能记不住那么多东西"
		},
		{
			"timestamps": {
				"from": "00:11:42,780",
				"to": "00:11:47,780"
			},
			"offsets": {
				"from": 702780,
				"to": 707780
			},
			"text": "但是你要按照自己的理解多去操作实践几遍"
		},
		{
			"timestamps": {
				"from": "00:11:47,780",
				"to": "00:11:50,780"
			},
			"offsets": {
				"from": 707780,
				"to": 710780
			},
			"text": "就能够把这个框架记下来了"
		},
		{
			"timestamps": {
				"from": "00:11:50,780",
				"to": "00:11:52,780"
			},
			"offsets": {
				"from": 710780,
				"to": 712780
			},
			"text": "我们标话的话一般来说"
		},
		{
			"timestamps": {
				"from": "00:11:52,780",
				"to": "00:11:57,780"
			},
			"offsets": {
				"from": 712780,
				"to": 717780
			},
			"text": "曝光量跟点击量的一个重要的衡量就是点击率"
		},
		{
			"timestamps": {
				"from": "00:11:57,780",
				"to": "00:12:00,780"
			},
			"offsets": {
				"from": 717780,
				"to": 720780
			},
			"text": "因为有曝光还到点击是吧"
		},
		{
			"timestamps": {
				"from": "00:12:00,780",
				"to": "00:12:04,780"
			},
			"offsets": {
				"from": 720780,
				"to": 724780
			},
			"text": "所以中间这个衡量指标就是点击率"
		},
		{
			"timestamps": {
				"from": "00:12:04,780",
				"to": "00:12:06,780"
			},
			"offsets": {
				"from": 724780,
				"to": 726780
			},
			"text": "通过这个点击率的衡量"
		},
		{
			"timestamps": {
				"from": "00:12:06,780",
				"to": "00:12:10,780"
			},
			"offsets": {
				"from": 726780,
				"to": 730780
			},
			"text": "它是否有效或者是说它是否在一个合理的范围"
		},
		{
			"timestamps": {
				"from": "00:12:10,780",
				"to": "00:12:15,780"
			},
			"offsets": {
				"from": 730780,
				"to": 735780
			},
			"text": "最后面我们来强调一个指标也就是点击量"
		},
		{
			"timestamps": {
				"from": "00:12:15,780",
				"to": "00:12:20,780"
			},
			"offsets": {
				"from": 735780,
				"to": 740780
			},
			"text": "点击量你看这一条线这是低点击量而高点击量"
		},
		{
			"timestamps": {
				"from": "00:12:20,780",
				"to": "00:12:22,780"
			},
			"offsets": {
				"from": 740780,
				"to": 742780
			},
			"text": "这边不是复数啊"
		},
		{
			"timestamps": {
				"from": "00:12:22,780",
				"to": "00:12:25,780"
			},
			"offsets": {
				"from": 742780,
				"to": 745780
			},
			"text": "比如说我的判断标准是以10个点击为起点"
		},
		{
			"timestamps": {
				"from": "00:12:25,780",
				"to": "00:12:28,780"
			},
			"offsets": {
				"from": 745780,
				"to": 748780
			},
			"text": "超过10个点击的算是高点击量"
		},
		{
			"timestamps": {
				"from": "00:12:28,780",
				"to": "00:12:31,780"
			},
			"offsets": {
				"from": 748780,
				"to": 751780
			},
			"text": "低于10个点击的是低点击量"
		},
		{
			"timestamps": {
				"from": "00:12:31,780",
				"to": "00:12:34,780"
			},
			"offsets": {
				"from": 751780,
				"to": 754780
			},
			"text": "当然这个10只是我的一个参考值"
		},
		{
			"timestamps": {
				"from": "00:12:34,780",
				"to": "00:12:38,780"
			},
			"offsets": {
				"from": 754780,
				"to": 758780
			},
			"text": "你可以设置成15或者20或者是30"
		},
		{
			"timestamps": {
				"from": "00:12:38,780",
				"to": "00:12:44,780"
			},
			"offsets": {
				"from": 758780,
				"to": 764780
			},
			"text": "因为你们店铺里面的产品的数量以及点击量都差距很大的"
		},
		{
			"timestamps": {
				"from": "00:12:44,780",
				"to": "00:12:51,780"
			},
			"offsets": {
				"from": 764780,
				"to": 771780
			},
			"text": "所以说这个指标你要根据自己的店铺来进行一个设置去选择优化"
		},
		{
			"timestamps": {
				"from": "00:12:51,780",
				"to": "00:12:53,780"
			},
			"offsets": {
				"from": 771780,
				"to": 773780
			},
			"text": "比如说你的是个门产品"
		},
		{
			"timestamps": {
				"from": "00:12:53,780",
				"to": "00:12:55,780"
			},
			"offsets": {
				"from": 773780,
				"to": 775780
			},
			"text": "通常它的点击量都是非常高的"
		},
		{
			"timestamps": {
				"from": "00:12:55,780",
				"to": "00:12:58,780"
			},
			"offsets": {
				"from": 775780,
				"to": 778780
			},
			"text": "而且你们店铺可能是几千上万个产品"
		},
		{
			"timestamps": {
				"from": "00:12:58,780",
				"to": "00:13:01,780"
			},
			"offsets": {
				"from": 778780,
				"to": 781780
			},
			"text": "那么产品实在是太多了是吧"
		},
		{
			"timestamps": {
				"from": "00:13:01,780",
				"to": "00:13:05,780"
			},
			"offsets": {
				"from": 781780,
				"to": 785780
			},
			"text": "如果产品太多那么你把这个点击量设置高一点"
		},
		{
			"timestamps": {
				"from": "00:13:05,780",
				"to": "00:13:12,780"
			},
			"offsets": {
				"from": 785780,
				"to": 792780
			},
			"text": "比如说你20起那么你能选择的产品优化的产品就会相对来说少一点"
		},
		{
			"timestamps": {
				"from": "00:13:12,780",
				"to": "00:13:17,780"
			},
			"offsets": {
				"from": 792780,
				"to": 797780
			},
			"text": "如果你也按照10个点击量来起步去优化的话"
		},
		{
			"timestamps": {
				"from": "00:13:17,780",
				"to": "00:13:19,780"
			},
			"offsets": {
				"from": 797780,
				"to": 799780
			},
			"text": "那么你整个店铺如果是上万个产品"
		},
		{
			"timestamps": {
				"from": "00:13:19,780",
				"to": "00:13:21,780"
			},
			"offsets": {
				"from": 799780,
				"to": 801780
			},
			"text": "又是热门行业的话"
		},
		{
			"timestamps": {
				"from": "00:13:21,780",
				"to": "00:13:25,780"
			},
			"offsets": {
				"from": 801780,
				"to": 805780
			},
			"text": "那么你这个就会发现非常多的产品需要你去优化"
		},
		{
			"timestamps": {
				"from": "00:13:25,780",
				"to": "00:13:29,780"
			},
			"offsets": {
				"from": 805780,
				"to": 809780
			},
			"text": "这就增加了你工作量而且有效性是比较低的"
		},
		{
			"timestamps": {
				"from": "00:13:29,780",
				"to": "00:13:33,780"
			},
			"offsets": {
				"from": 809780,
				"to": 813780
			},
			"text": "如果你是冷门行业的你就一定按照10这个起步"
		},
		{
			"timestamps": {
				"from": "00:13:33,780",
				"to": "00:13:36,780"
			},
			"offsets": {
				"from": 813780,
				"to": 816780
			},
			"text": "比如说你冷门行业可能就是600个产品是吧"
		},
		{
			"timestamps": {
				"from": "00:13:36,780",
				"to": "00:13:38,780"
			},
			"offsets": {
				"from": 816780,
				"to": 818780
			},
			"text": "5到600个产品"
		},
		{
			"timestamps": {
				"from": "00:13:38,780",
				"to": "00:13:42,780"
			},
			"offsets": {
				"from": 818780,
				"to": 822780
			},
			"text": "你的本身店铺的流量就本身就几少了"
		},
		{
			"timestamps": {
				"from": "00:13:42,780",
				"to": "00:13:46,780"
			},
			"offsets": {
				"from": 822780,
				"to": 826780
			},
			"text": "能够有10个点击的产品都是非常少的"
		},
		{
			"timestamps": {
				"from": "00:13:46,780",
				"to": "00:13:48,780"
			},
			"offsets": {
				"from": 826780,
				"to": 828780
			},
			"text": "那么这种情况你不一定说要设置10"
		},
		{
			"timestamps": {
				"from": "00:13:48,780",
				"to": "00:13:51,780"
			},
			"offsets": {
				"from": 828780,
				"to": 831780
			},
			"text": "可能你要设置的是8个点击"
		},
		{
			"timestamps": {
				"from": "00:13:51,780",
				"to": "00:13:54,780"
			},
			"offsets": {
				"from": 831780,
				"to": 834780
			},
			"text": "我也去按照这个上线来进行优化"
		},
		{
			"timestamps": {
				"from": "00:13:54,780",
				"to": "00:13:59,780"
			},
			"offsets": {
				"from": 834780,
				"to": 839780
			},
			"text": "或者是说你也按照标准10个点击去优化就可以了"
		},
		{
			"timestamps": {
				"from": "00:13:59,780",
				"to": "00:14:03,780"
			},
			"offsets": {
				"from": 839780,
				"to": 843780
			},
			"text": "所以说这个冷门行业跟热门行业"
		},
		{
			"timestamps": {
				"from": "00:14:03,780",
				"to": "00:14:09,780"
			},
			"offsets": {
				"from": 843780,
				"to": 849780
			},
			"text": "它选择的一个指标是可以根据你自己店铺的实际情况来调整的"
		},
		{
			"timestamps": {
				"from": "00:14:09,780",
				"to": "00:14:15,780"
			},
			"offsets": {
				"from": 849780,
				"to": 855780
			},
			"text": "因为这个衡量的一个起始的数值会决定着你需要优化产品的数量"
		},
		{
			"timestamps": {
				"from": "00:14:15,780",
				"to": "00:14:21,780"
			},
			"offsets": {
				"from": 855780,
				"to": 861780
			},
			"text": "所以我们一定要根据自己的店铺去把这个数值确定下来"
		},
		{
			"timestamps": {
				"from": "00:14:21,780",
				"to": "00:14:24,780"
			},
			"offsets": {
				"from": 861780,
				"to": 864780
			},
			"text": "再去优化一定要灵活变通一点"
		},
		{
			"timestamps": {
				"from": "00:14:24,780",
				"to": "00:14:30,780"
			},
			"offsets": {
				"from": 864780,
				"to": 870780
			},
			"text": "那么这节课我们就讲了关于曝光量点击量这个四项线的优化方法"
		},
		{
			"timestamps": {
				"from": "00:14:30,780",
				"to": "00:14:33,780"
			},
			"offsets": {
				"from": 870780,
				"to": 873780
			},
			"text": "如果你还没有足够的清晰"
		},
		{
			"timestamps": {
				"from": "00:14:33,780",
				"to": "00:14:39,780"
			},
			"offsets": {
				"from": 873780,
				"to": 879780
			},
			"text": "建议你多听一次再根据店铺里面的实际案例去操作一次"
		},
		{
			"timestamps": {
				"from": "00:14:39,780",
				"to": "00:14:44,780"
			},
			"offsets": {
				"from": 879780,
				"to": 884780
			},
			"text": "那么我相信一定能够帮你更好的理解产品如何去优化"
		},
		{
			"timestamps": {
				"from": "00:14:44,780",
				"to": "00:14:48,300"
			},
			"offsets": {
				"from": 884780,
				"to": 888300
			},
			"text": "那么这节课我们就先讲到这里"
		}
	]
}
