				"to": 393860
			},
			"text": "它能不能获得更多的这些流量呢"
		},
		{
			"timestamps": {
				"from": "00:06:33,860",
				"to": "00:06:36,000"
			},
			"offsets": {
				"from": 393860,
				"to": 396000
			},
			"text": "那么它如果获得更多流量"
		},
		{
			"timestamps": {
				"from": "00:06:36,000",
				"to": "00:06:38,760"
			},
			"offsets": {
				"from": 396000,
				"to": 398760
			},
			"text": "那么你的场景流量就会再增长"
		},
		{
			"timestamps": {
				"from": "00:06:38,760",
				"to": "00:06:41,500"
			},
			"offsets": {
				"from": 398760,
				"to": 401500
			},
			"text": "那么你的店铺的总流量也会再增长"
		},
		{
			"timestamps": {
				"from": "00:06:41,500",
				"to": "00:06:45,340"
			},
			"offsets": {
				"from": 401500,
				"to": 405340
			},
			"text": "所以呢 它是一连串的反应的"
		},
		{
			"timestamps": {
				"from": "00:06:45,340",
				"to": "00:06:51,120"
			},
			"offsets": {
				"from": 405340,
				"to": 411120
			},
			"text": "从源头开始 就是你选的品类开始 作为一个源头的入口"
		},
		{
			"timestamps": {
				"from": "00:06:51,120",
				"to": "00:06:57,440"
			},
			"offsets": {
				"from": 411120,
				"to": 417440
			},
			"text": "当你的品类在增加的时候 你所覆盖的国家可能增加 也可能不增加"
		},
		{
			"timestamps": {
				"from": "00:06:57,440",
				"to": "00:07:04,680"
			},
			"offsets": {
				"from": 417440,
				"to": 424680
			},
			"text": "但是它的池一定是在增加的 池增加的时候 是不是池的排名你做起来了 是不是有排名"
		},
		{
			"timestamps": {
				"from": "00:07:04,680",
				"to": "00:07:12,080"
			},
			"offsets": {
				"from": 424680,
				"to": 432080
			},
			"text": "同时它的流量是不是会增长 如果你在这新增的品类里面打造出爆品 是不是场景流量会增长"
		},
		{
			"timestamps": {
				"from": "00:07:12,080",
				"to": "00:07:19,140"
			},
			"offsets": {
				"from": 432080,
				"to": 439140
			},
			"text": "所以我们一定要记住店铺流量的增长逻辑 它是由这么多因子决定的"
		},
		{
			"timestamps": {
				"from": "00:07:19,140",
				"to": "00:07:24,440"
			},
			"offsets": {
				"from": 439140,
				"to": 444440
			},
			"text": "那么我们在日常操作的时候就会知道我们该怎么样去突破"
		},
		{
			"timestamps": {
				"from": "00:07:24,440",
				"to": "00:07:29,240"
			},
			"offsets": {
				"from": 444440,
				"to": 449240
			},
			"text": "同时呢 我们一定要记住这个店铺的一个增长模型"
		},
		{
			"timestamps": {
				"from": "00:07:29,240",
				"to": "00:07:35,100"
			},
			"offsets": {
				"from": 449240,
				"to": 455100
			},
			"text": "它是由这么多因子决定的 你的因子每个做得越好"
		},
		{
			"timestamps": {
				"from": "00:07:35,100",
				"to": "00:07:38,460"
			},
			"offsets": {
				"from": 455100,
				"to": 458460
			},
			"text": "那么都是在提升你整个店铺的总流量"
		},
		{
			"timestamps": {
				"from": "00:07:38,460",
				"to": "00:07:50,200"
			},
			"offsets": {
				"from": 458460,
				"to": 470200
			},
			"text": "理解吧 那么我们举个例子吧 比如说 A店铺 3 月份 4 月份 效果挺好的 是吧 突然间到了 5 月 6 月效果差了"
		},
		{
			"timestamps": {
				"from": "00:07:50,200",
				"to": "00:07:58,460"
			},
			"offsets": {
				"from": 470200,
				"to": 478460
			},
			"text": "那么我们怎么样去分析它效果变差了呢 你就要从这些维度去看 比如说品类 你有没有在减少"
		},
		{
			"timestamps": {
				"from": "00:07:58,460",
				"to": "00:08:05,600"
			},
			"offsets": {
				"from": 478460,
				"to": 485600
			},
			"text": "或者是说你的品类里面的这些关键词 有排名的关键词是不是在减少"
		},
		{
			"timestamps": {
				"from": "00:08:05,600",
				"to": "00:08:08,920"
			},
			"offsets": {
				"from": 485600,
				"to": 488920
			},
			"text": "他们排名的位置是不是在减少"
		},
		{
			"timestamps": {
				"from": "00:08:08,920",
				"to": "00:08:14,220"
			},
			"offsets": {
				"from": 488920,
				"to": 494220
			},
			"text": "那么他里面的这些产品是不是增报品变少了"
		},
		{
			"timestamps": {
				"from": "00:08:14,220",
				"to": "00:08:15,640"
			},
			"offsets": {
				"from": 494220,
				"to": 495640
			},
			"text": "是不是在下降"
		},
		{
			"timestamps": {
				"from": "00:08:15,640",
				"to": "00:08:18,340"
			},
			"offsets": {
				"from": 495640,
				"to": 498340
			},
			"text": "那么你看这一连串的反应"
		},
		{
			"timestamps": {
				"from": "00:08:18,340",
				"to": "00:08:24,320"
			},
			"offsets": {
				"from": 498340,
				"to": 504320
			},
			"text": "就是导致你5月跟6月效果变差的一个关键的影响指标"
		},
		{
			"timestamps": {
				"from": "00:08:24,320",
				"to": "00:08:29,360"
			},
			"offsets": {
				"from": 504320,
				"to": 509360
			},
			"text": "也就是我们要去从产品这个维度进行切入去分析的"
		},
		{
			"timestamps": {
				"from": "00:08:29,360",
				"to": "00:08:33,980"
			},
			"offsets": {
				"from": 509360,
				"to": 513980
			},
			"text": "因为那种产品能够衍生出国家关键词排名"
		},
		{
			"timestamps": {
				"from": "00:08:33,980",
				"to": "00:08:39,280"
			},
			"offsets": {
				"from": 513980,
				"to": 519280
			},
			"text": "还有排名的位置 还有场景流量 一切的源头都在于产品"
		},
		{
			"timestamps": {
				"from": "00:08:39,280",
				"to": "00:08:42,160"
			},
			"offsets": {
				"from": 519280,
				"to": 522160
			},
			"text": "这个就是开端 产品就是开端"
		},
		{
			"timestamps": {
				"from": "00:08:42,160",
				"to": "00:08:48,080"
			},
			"offsets": {
				"from": 522160,
				"to": 528080
			},
			"text": "所以我们只要捉住源头的问题 像洋葱一样一层一层的去拨开"
		},
		{
			"timestamps": {
				"from": "00:08:48,080",
				"to": "00:08:54,680"
			},
			"offsets": {
				"from": 528080,
				"to": 534680
			},
			"text": "那么我们就能够知道我们店铺为什么流量增长 为什么流量在暴跌"
		},
		{
			"timestamps": {
				"from": "00:08:54,680",
				"to": "00:09:00,500"
			},
			"offsets": {
				"from": 534680,
				"to": 540500
			},
			"text": "通过这个店铺流量增长的逻辑 你就能够非常快的找到问题"
		},
		{
			"timestamps": {
				"from": "00:09:00,500",
				"to": "00:09:03,520"
			},
			"offsets": {
				"from": 540500,
				"to": 543520
			},
			"text": "并针对性的去解决这些问题"
		},
		{
			"timestamps": {
				"from": "00:09:03,520",
				"to": "00:09:10,020"
			},
			"offsets": {
				"from": 543520,
				"to": 550020
			},
			"text": "那么这些都是关于操作层面的 那么关于店铺层题的又是怎么回事呢"
		},
		{
			"timestamps": {
				"from": "00:09:10,020",
				"to": "00:09:18,380"
			},
			"offsets": {
				"from": 550020,
				"to": 558380
			},
			"text": "比如说我们这些指标基本都不变 是吧 那么我们原始可能只做定制加RTS赛道的"
		},
		{
			"timestamps": {
				"from": "00:09:18,380",
				"to": "00:09:27,540"
			},
			"offsets": {
				"from": 558380,
				"to": 567540
			},
			"text": "近期国际上推出半托管这一个场景 那么如果我们店铺里面直接去增加这个品类的产品"
		},
		{
			"timestamps": {
				"from": "00:09:27,540",
				"to": "00:09:32,580"
			},
			"offsets": {
				"from": 567540,
				"to": 572580
			},
			"text": "是不是相当于我们店铺里面增加了一条流量的入口"
		},
		{
			"timestamps": {
				"from": "00:09:32,580",
				"to": "00:09:41,480"
			},
			"offsets": {
				"from": 572580,
				"to": 581480
			},
			"text": "那么流量的入口增加了 同时你发的这些半托管产品的效果也比较好 效果也比较好"
		},
		{
			"timestamps": {
				"from": "00:09:41,480",
				"to": "00:09:52,040"
			},
			"offsets": {
				"from": 581480,
				"to": 592040
			},
			"text": "那么你这个店铺的总流量得到增长的 也是会增长的 因为之前我们是靠定制跟RTS这两个赛道 这是第二个 这两个流量入口"
		},
		{
			"timestamps": {
				"from": "00:09:52,040",
				"to": "00:10:01,040"
			},
			"offsets": {
				"from": 592040,
				"to": 601040
			},
			"text": "现在增加了半托 这个半托相当于三条流量入口平台里面的流量 通过三条路径进入到你的店铺"
		},
		{
			"timestamps": {
				"from": "00:10:01,040",
				"to": "00:10:04,220"
			},
			"offsets": {
				"from": 601040,
				"to": 604220
			},
			"text": "是不是就容易拉升我们整个店铺的流量"
		},
		{
			"timestamps": {
				"from": "00:10:04,220",
				"to": "00:10:06,580"
			},
			"offsets": {
				"from": 604220,
				"to": 606580
			},
			"text": "它也是一样的逻辑"
		},
		{
			"timestamps": {
				"from": "00:10:06,580",
				"to": "00:10:10,380"
			},
			"offsets": {
				"from": 606580,
				"to": 610380
			},
			"text": "所以我们要从细节维度跟店铺层级的维度"
		},
		{
			"timestamps": {
				"from": "00:10:10,380",
				"to": "00:10:12,320"
			},
			"offsets": {
				"from": 610380,
				"to": 612320
			},
			"text": "店铺层级是一个非常大的维度"
		},
		{
			"timestamps": {
				"from": "00:10:12,320",
				"to": "00:10:15,160"
			},
			"offsets": {
				"from": 612320,
				"to": 615160
			},
			"text": "去提升我们店铺的整体的效果"
		},
		{
			"timestamps": {
				"from": "00:10:15,160",
				"to": "00:10:16,500"
			},
			"offsets": {
				"from": 615160,
				"to": 616500
			},
			"text": "其实说了那么多"
		},
		{
			"timestamps": {
				"from": "00:10:16,500",
				"to": "00:10:18,260"
			},
			"offsets": {
				"from": 616500,
				"to": 618260
			},
			"text": "我就是想让大家知道"
		},
		{
			"timestamps": {
				"from": "00:10:18,260",
				"to": "00:10:21,000"
			},
			"offsets": {
				"from": 618260,
				"to": 621000
			},
			"text": "店铺流量的增长与什么因子有关"
		},
		{
			"timestamps": {
				"from": "00:10:21,000",
				"to": "00:10:24,340"
			},
			"offsets": {
				"from": 621000,
				"to": 624340
			},
			"text": "以及我们可以去调整和优化哪些指标"
		},
		{
			"timestamps": {
				"from": "00:10:24,340",
				"to": "00:10:26,680"
			},
			"offsets": {
				"from": 624340,
				"to": 626680
			},
			"text": "如何去判断 如何去分析"
		},
		{
			"timestamps": {
				"from": "00:10:26,680",
				"to": "00:10:28,860"
			},
			"offsets": {
				"from": 626680,
				"to": 628860
			},
			"text": "这些方法我们前面都学过了"
		},
		{
			"timestamps": {
				"from": "00:10:28,860",
				"to": "00:10:31,960"
			},
			"offsets": {
				"from": 628860,
				"to": 631960
			},
			"text": "所以这个模型你只要记住了"
		},
		{
			"timestamps": {
				"from": "00:10:31,960",
				"to": "00:10:37,400"
			},
			"offsets": {
				"from": 631960,
				"to": 637400
			},
			"text": "那么对于你以后去判断去分析都是有非常清晰的思路的"
		},
		{
			"timestamps": {
				"from": "00:10:37,400",
				"to": "00:10:38,820"
			},
			"offsets": {
				"from": 637400,
				"to": 638820
			},
			"text": "只要你有思路"
		},
		{
			"timestamps": {
				"from": "00:10:38,820",
				"to": "00:10:44,140"
			},
			"offsets": {
				"from": 638820,
				"to": 644140
			},
			"text": "那么你就一定能够去不断的找新的方法去解决这个问题"
		},
		{
			"timestamps": {
				"from": "00:10:44,140",
				"to": "00:10:47,200"
			},
			"offsets": {
				"from": 644140,
				"to": 647200
			},
			"text": "但是很多时候因为我们没有思路"
		},
		{
			"timestamps": {
				"from": "00:10:47,200",
				"to": "00:10:49,840"
			},
			"offsets": {
				"from": 647200,
				"to": 649840
			},
			"text": "所以才不知道我们怎么样去做"
		},
		{
			"timestamps": {
				"from": "00:10:49,840",
				"to": "00:10:52,880"
			},
			"offsets": {
				"from": 649840,
				"to": 652880
			},
			"text": "即使你有方法但是你没有思路"
		},
		{
			"timestamps": {
				"from": "00:10:52,880",
				"to": "00:10:56,320"
			},
			"offsets": {
				"from": 652880,
				"to": 656320
			},
			"text": "你也不知道你这个方法是在解决你这个问题"
		},
		{
			"timestamps": {
				"from": "00:10:56,320",
				"to": "00:11:22,460"
			},
			"offsets": {
				"from": 656320,
				"to": 682460
			},
			"text": "所以说 思路非常重要 你不重视思路和不重视分析的一些维度 那么你的方法都是失效的 你只有有了思路 有了一些具体的判断指标 那么你的方法才能够更有针对性 才能够更快的起作用 这个增长逻辑大家一定要重视起来 那么这节课 我们就先讲到这里 下节课 我们再见"
		}
	]
}
