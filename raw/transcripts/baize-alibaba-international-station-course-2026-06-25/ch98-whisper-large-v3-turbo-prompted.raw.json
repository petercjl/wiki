				"to": "00:07:17,780"
			},
			"offsets": {
				"from": 428140,
				"to": 437780
			},
			"text": "那么你可以更新一些其他的结构 但是你要遵从这个搜索规则 以及流量规则去写就可以了"
		},
		{
			"timestamps": {
				"from": "00:07:17,780",
				"to": "00:07:22,480"
			},
			"offsets": {
				"from": 437780,
				"to": 442480
			},
			"text": "最后面我们来注意几个事项 第一个就是关键词"
		},
		{
			"timestamps": {
				"from": "00:07:22,480",
				"to": "00:07:51,800"
			},
			"offsets": {
				"from": 442480,
				"to": 471800
			},
			"text": "我们刚才在关键词搜索指数里面查找了那些关键词 一定是有搜索指数的 也就是在那个列表里面有出现的词 第二个就是搜索指数一定大小顺序一定要排好 排好 你一定要记住那个逻辑 从左往右搜索指数是上涨的 从左往右搜索指数上涨 这边是搜索指数低的 第三个就是标题不要一次性写满 128个 因为"
		},
		{
			"timestamps": {
				"from": "00:07:52,480",
				"to": "00:07:56,060"
			},
			"offsets": {
				"from": 472480,
				"to": 476060
			},
			"text": "爆款的标题都是由短标题衍生出来的"
		},
		{
			"timestamps": {
				"from": "00:07:56,060",
				"to": "00:07:59,400"
			},
			"offsets": {
				"from": 476060,
				"to": 479400
			},
			"text": "第四个就是能不用借词的尽量不要用"
		},
		{
			"timestamps": {
				"from": "00:07:59,400",
				"to": "00:08:01,700"
			},
			"offsets": {
				"from": 479400,
				"to": 481700
			},
			"text": "借词的能不用的尽量不要用"
		},
		{
			"timestamps": {
				"from": "00:08:01,700",
				"to": "00:08:05,540"
			},
			"offsets": {
				"from": 481700,
				"to": 485540
			},
			"text": "如果你在关键词搜索指数里面所用的词"
		},
		{
			"timestamps": {
				"from": "00:08:05,540",
				"to": "00:08:08,600"
			},
			"offsets": {
				"from": 485540,
				"to": 488600
			},
			"text": "所搜索出来的词都没有借词的时候"
		},
		{
			"timestamps": {
				"from": "00:08:08,600",
				"to": "00:08:11,420"
			},
			"offsets": {
				"from": 488600,
				"to": 491420
			},
			"text": "你就不要自己去强加一个借词了"
		},
		{
			"timestamps": {
				"from": "00:08:11,420",
				"to": "00:08:13,220"
			},
			"offsets": {
				"from": 491420,
				"to": 493220
			},
			"text": "没有你就可以完全不用"
		},
		{
			"timestamps": {
				"from": "00:08:13,220",
				"to": "00:08:16,040"
			},
			"offsets": {
				"from": 493220,
				"to": 496040
			},
			"text": "第五个就是避免堆砌 也就是我们常说的"
		},
		{
			"timestamps": {
				"from": "00:08:16,040",
				"to": "00:08:18,840"
			},
			"offsets": {
				"from": 496040,
				"to": 498840
			},
			"text": "同样的关键词不能超过三次"
		},
		{
			"timestamps": {
				"from": "00:08:18,840",
				"to": "00:08:20,120"
			},
			"offsets": {
				"from": 498840,
				"to": 500120
			},
			"text": "不能超过三次"
		},
		{
			"timestamps": {
				"from": "00:08:20,640",
				"to": "00:08:49,740"
			},
			"offsets": {
				"from": 500640,
				"to": 529740
			},
			"text": "有些人用了四次 五次同样的关键词在一个标题 作用不大的 它和用一到两个关键词的效果还差 并不是说这些关键词用的多 它的效果就越好呢 所以一定要注意这几个12345 5点 那么我们最后面来总结一下 第一个一定要知道标题的权重排序 第二个就是你一定要掌握一个比较标准的一个标题组合的流程"
		},
		{
			"timestamps": {
				"from": "00:08:49,740",
				"to": "00:09:09,080"
			},
			"offsets": {
				"from": 529740,
				"to": 549080
			},
			"text": "或者是一个框架你要去掌握 因为你只有知道它的一个流量的逻辑 它的一个平台的一个规则 以及它哪些部分是重要的 你知道的这些 你在掌握一个就是 你这个标题都有哪些结构"
		},
		{
			"timestamps": {
				"from": "00:09:09,080",
				"to": "00:09:18,580"
			},
			"offsets": {
				"from": 549080,
				"to": 558580
			},
			"text": "那么你是不是就能够非常清晰的去组合一个标题了 而且是比较符合平台规则的 只有符合平台规则你才能够拿得到"
		},
		{
			"timestamps": {
				"from": "00:09:18,580",
				"to": "00:09:24,740"
			},
			"offsets": {
				"from": 558580,
				"to": 564740
			},
			"text": "更多的流量分配权 同时呢 你在做推广啊 各方面啊 那么你只要符合平台的规则"
		},
		{
			"timestamps": {
				"from": "00:09:24,740",
				"to": "00:09:34,660"
			},
			"offsets": {
				"from": 564740,
				"to": 574660
			},
			"text": "那么你得到的流量就更加容易 你的竞争力就更加高 排名就更加好 排名好了是不是产品能够得到的流量就更多"
		},
		{
			"timestamps": {
				"from": "00:09:34,660",
				"to": "00:09:41,280"
			},
			"offsets": {
				"from": 574660,
				"to": 581280
			},
			"text": "所以这个是一个一环扣一环的 它是一环扣一环的 而不是单独存在的"
		},
		{
			"timestamps": {
				"from": "00:09:41,280",
				"to": "00:09:47,200"
			},
			"offsets": {
				"from": 581280,
				"to": 587200
			},
			"text": "所以为什么我们平时学习一定要学习它的概念 先学到概念 知道它的概念是什么"
		},
		{
			"timestamps": {
				"from": "00:09:47,200",
				"to": "00:09:56,880"
			},
			"offsets": {
				"from": 587200,
				"to": 596880
			},
			"text": "第二个就是知道平台的规则 然后再根据平台的规则 去做一些符合它的逻辑的东西内容 才能够获得更多的流量"
		},
		{
			"timestamps": {
				"from": "00:09:56,880",
				"to": "00:10:10,820"
			},
			"offsets": {
				"from": 596880,
				"to": 610820
			},
			"text": "最后这个就是刚才我们讲的标题组合 要注意那几个事项 最后面你可以开始自己按照前面的内容的理解 然后去组5到10个爆款标题"
		},
		{
			"timestamps": {
				"from": "00:10:11,240",
				"to": "00:10:19,940"
			},
			"offsets": {
				"from": 611240,
				"to": 619940
			},
			"text": "如果你对上面的一些概念 或者是说一些规则 不是很理解 那么你还可以再去听一遍"
		},
		{
			"timestamps": {
				"from": "00:10:19,940",
				"to": "00:10:30,700"
			},
			"offsets": {
				"from": 619940,
				"to": 630700
			},
			"text": "也许能够有更深的理解 再去行动起来 一定要去做 如果是你感觉你听懂了 但是你还是你又不去做"
		},
		{
			"timestamps": {
				"from": "00:10:30,700",
				"to": "00:10:38,380"
			},
			"offsets": {
				"from": 630700,
				"to": 638380
			},
			"text": "那么你其实是很可能就学不会 你只是知道的这个东西 但是你没有真正的掌握 所以一定要行动起来"
		},
		{
			"timestamps": {
				"from": "00:10:38,380",
				"to": "00:10:45,780"
			},
			"offsets": {
				"from": 638380,
				"to": 645780
			},
			"text": "好了 这节课我们就先讲到这里 下节课我们就主要来讲解关于爆款标题怎么组合"
		}
	]
}
