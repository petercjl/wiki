				"to": 385420
			},
			"text": "买家参谋这里一定是去看行业买家的"
		},
		{
			"timestamps": {
				"from": "00:06:25,420",
				"to": "00:06:28,420"
			},
			"offsets": {
				"from": 385420,
				"to": 388420
			},
			"text": "行业买家这里的数据维度我们可以选"
		},
		{
			"timestamps": {
				"from": "00:06:28,420",
				"to": "00:06:31,420"
			},
			"offsets": {
				"from": 388420,
				"to": 391420
			},
			"text": "30天啊90天这些大一点的维度"
		},
		{
			"timestamps": {
				"from": "00:06:31,420",
				"to": "00:06:34,420"
			},
			"offsets": {
				"from": 391420,
				"to": 394420
			},
			"text": "废幕的话你要选相对来说细分一点点的废幕"
		},
		{
			"timestamps": {
				"from": "00:06:34,420",
				"to": "00:06:37,420"
			},
			"offsets": {
				"from": 394420,
				"to": 397420
			},
			"text": "这里选什么?主要以订单买家为主"
		},
		{
			"timestamps": {
				"from": "00:06:37,420",
				"to": "00:06:38,420"
			},
			"offsets": {
				"from": 397420,
				"to": 398420
			},
			"text": "往下拉"
		},
		{
			"timestamps": {
				"from": "00:06:38,420",
				"to": "00:06:41,420"
			},
			"offsets": {
				"from": 398420,
				"to": 401420
			},
			"text": "你看这里是不是这些国家的一个分布"
		},
		{
			"timestamps": {
				"from": "00:06:41,420",
				"to": "00:06:43,420"
			},
			"offsets": {
				"from": 401420,
				"to": 403420
			},
			"text": "你去把内幕选好了"
		},
		{
			"timestamps": {
				"from": "00:06:43,420",
				"to": "00:06:48,420"
			},
			"offsets": {
				"from": 403420,
				"to": 408420
			},
			"text": "把订单买家, 群盘买家, 贴母买家的这三个数据维度"
		},
		{
			"timestamps": {
				"from": "00:06:48,420",
				"to": "00:06:51,420"
			},
			"offsets": {
				"from": 408420,
				"to": 411420
			},
			"text": "三个数据维度去复制到表格"
		},
		{
			"timestamps": {
				"from": "00:06:51,420",
				"to": "00:06:53,420"
			},
			"offsets": {
				"from": 411420,
				"to": 413420
			},
			"text": "找到他们的交集"
		},
		{
			"timestamps": {
				"from": "00:06:53,420",
				"to": "00:06:56,420"
			},
			"offsets": {
				"from": 413420,
				"to": 416420
			},
			"text": "保留大概10到20个国家"
		},
		{
			"timestamps": {
				"from": "00:06:56,420",
				"to": "00:06:58,420"
			},
			"offsets": {
				"from": 416420,
				"to": 418420
			},
			"text": "再进行一个测试"
		},
		{
			"timestamps": {
				"from": "00:06:58,420",
				"to": "00:07:00,420"
			},
			"offsets": {
				"from": 418420,
				"to": 420420
			},
			"text": "测完了之后呢"
		},
		{
			"timestamps": {
				"from": "00:07:00,420",
				"to": "00:07:02,420"
			},
			"offsets": {
				"from": 420420,
				"to": 422420
			},
			"text": "我们再缩减一些国家就可以了"
		},
		{
			"timestamps": {
				"from": "00:07:02,420",
				"to": "00:07:04,420"
			},
			"offsets": {
				"from": 422420,
				"to": 424420
			},
			"text": "比如说5个到10个国家"
		},
		{
			"timestamps": {
				"from": "00:07:04,420",
				"to": "00:07:07,420"
			},
			"offsets": {
				"from": 424420,
				"to": 427420
			},
			"text": "去看一下这些国家的转化率"
		},
		{
			"timestamps": {
				"from": "00:07:07,420",
				"to": "00:07:10,420"
			},
			"offsets": {
				"from": 427420,
				"to": 430420
			},
			"text": "我们也可以根据我们选择出的这些国家"
		},
		{
			"timestamps": {
				"from": "00:07:10,420",
				"to": "00:07:13,420"
			},
			"offsets": {
				"from": 430420,
				"to": 433420
			},
			"text": "去选择产品的类型和款式"
		},
		{
			"timestamps": {
				"from": "00:07:13,420",
				"to": "00:07:14,420"
			},
			"offsets": {
				"from": 433420,
				"to": 434420
			},
			"text": "去进行一个推广"
		},
		{
			"timestamps": {
				"from": "00:07:14,420",
				"to": "00:07:18,420"
			},
			"offsets": {
				"from": 434420,
				"to": 438420
			},
			"text": "那么我们是不是产品更加符合这些国家"
		},
		{
			"timestamps": {
				"from": "00:07:18,420",
				"to": "00:07:21,420"
			},
			"offsets": {
				"from": 438420,
				"to": 441420
			},
			"text": "那么是不是可能效果会更好一点"
		},
		{
			"timestamps": {
				"from": "00:07:21,420",
				"to": "00:07:24,420"
			},
			"offsets": {
				"from": 441420,
				"to": 444420
			},
			"text": "所以这些维度都能够帮助我们"
		},
		{
			"timestamps": {
				"from": "00:07:24,420",
				"to": "00:07:26,420"
			},
			"offsets": {
				"from": 444420,
				"to": 446420
			},
			"text": "细致的去选择目标的市场"
		},
		{
			"timestamps": {
				"from": "00:07:26,420",
				"to": "00:07:28,420"
			},
			"offsets": {
				"from": 446420,
				"to": 448420
			},
			"text": "以及我们的产品的类型"
		},
		{
			"timestamps": {
				"from": "00:07:28,420",
				"to": "00:07:30,420"
			},
			"offsets": {
				"from": 448420,
				"to": 450420
			},
			"text": "至于数据的标准"
		},
		{
			"timestamps": {
				"from": "00:07:30,420",
				"to": "00:07:32,420"
			},
			"offsets": {
				"from": 450420,
				"to": 452420
			},
			"text": "不要被调调框所限制"
		},
		{
			"timestamps": {
				"from": "00:07:32,420",
				"to": "00:07:34,420"
			},
			"offsets": {
				"from": 452420,
				"to": 454420
			},
			"text": "一定要灵活一点点就可以了"
		},
		{
			"timestamps": {
				"from": "00:07:34,420",
				"to": "00:07:36,420"
			},
			"offsets": {
				"from": 454420,
				"to": 456420
			},
			"text": "这个就是关于我们店铺"
		},
		{
			"timestamps": {
				"from": "00:07:36,420",
				"to": "00:07:38,420"
			},
			"offsets": {
				"from": 456420,
				"to": 458420
			},
			"text": "一定要选择目标市场"
		},
		{
			"timestamps": {
				"from": "00:07:38,420",
				"to": "00:07:40,420"
			},
			"offsets": {
				"from": 458420,
				"to": 460420
			},
			"text": "去精准的推广"
		},
		{
			"timestamps": {
				"from": "00:07:40,420",
				"to": "00:07:42,420"
			},
			"offsets": {
				"from": 460420,
				"to": 462420
			},
			"text": "把资源集中起来去应用"
		},
		{
			"timestamps": {
				"from": "00:07:42,420",
				"to": "00:07:46,420"
			},
			"offsets": {
				"from": 462420,
				"to": 466420
			},
			"text": "这样才能够让我们的店铺更快的成长起来"
		},
		{
			"timestamps": {
				"from": "00:07:46,420",
				"to": "00:07:49,420"
			},
			"offsets": {
				"from": 466420,
				"to": 469420
			},
			"text": "大家一定要重视去行动"
		},
		{
			"timestamps": {
				"from": "00:07:49,420",
				"to": "00:07:51,420"
			},
			"offsets": {
				"from": 469420,
				"to": 471420
			},
			"text": "好了这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:07:51,420",
				"to": "00:07:53,420"
			},
			"offsets": {
				"from": 471420,
				"to": 473420
			},
			"text": "下节课我们再见"
		}
	]
}
