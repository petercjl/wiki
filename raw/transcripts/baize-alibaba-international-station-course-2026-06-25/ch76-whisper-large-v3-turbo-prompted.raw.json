			},
			"offsets": {
				"from": 301360,
				"to": 305740
			},
			"text": "也就是这个板块有曝光点击跟访客"
		},
		{
			"timestamps": {
				"from": "00:05:05,740",
				"to": "00:05:10,780"
			},
			"offsets": {
				"from": 305740,
				"to": 310780
			},
			"text": "那么有了曝光点击访客之后就会有寻盘跟贴母"
		},
		{
			"timestamps": {
				"from": "00:05:10,780",
				"to": "00:05:14,740"
			},
			"offsets": {
				"from": 310780,
				"to": 314740
			},
			"text": "寻盘跟贴母之后就会要解决订单量的问题"
		},
		{
			"timestamps": {
				"from": "00:05:14,740",
				"to": "00:05:20,560"
			},
			"offsets": {
				"from": 314740,
				"to": 320560
			},
			"text": "所以我们在解决整个店铺细分维度的时候"
		},
		{
			"timestamps": {
				"from": "00:05:20,560",
				"to": "00:05:23,980"
			},
			"offsets": {
				"from": 320560,
				"to": 323980
			},
			"text": "我们一定要先根据这三大问题"
		},
		{
			"timestamps": {
				"from": "00:05:23,980",
				"to": "00:05:28,940"
			},
			"offsets": {
				"from": 323980,
				"to": 328940
			},
			"text": "然后再找到对应的指标进行细分去优化"
		},
		{
			"timestamps": {
				"from": "00:05:28,940",
				"to": "00:05:35,080"
			},
			"offsets": {
				"from": 328940,
				"to": 335080
			},
			"text": "比如说你店铺现在就是在曝光点击访客这些板块存在的问题"
		},
		{
			"timestamps": {
				"from": "00:05:35,080",
				"to": "00:05:38,020"
			},
			"offsets": {
				"from": 335080,
				"to": 338020
			},
			"text": "那么你就不要先考虑后面这些问题"
		},
		{
			"timestamps": {
				"from": "00:05:38,020",
				"to": "00:05:40,780"
			},
			"offsets": {
				"from": 338020,
				"to": 340780
			},
			"text": "你应该先把前面这些问题解决了"
		},
		{
			"timestamps": {
				"from": "00:05:40,780",
				"to": "00:05:43,920"
			},
			"offsets": {
				"from": 340780,
				"to": 343920
			},
			"text": "有些店铺就像我们前面上一小节所讲的"
		},
		{
			"timestamps": {
				"from": "00:05:43,920",
				"to": "00:06:13,900"
			},
			"offsets": {
				"from": 343920,
				"to": 373900
			},
			"text": "连访客量都不多, 那你就直接来问, 为什么没有选拔, 那你要先解决访客的问题啊, 所以不要直接就跳过了这些流量的问题, 直接问到结果的问题, 曝光跟点击之间, 会有一个衡量的指标, 就是点击率, 那么点击率, 我们只要在0.8到4%都是比较合理的, 那么我们这里看的数据, 全部都是全店的综合数据啊, 不是单品, 也不是单个板块的数据,"
		},
		{
			"timestamps": {
				"from": "00:06:13,920",
				"to": "00:06:19,100"
			},
			"offsets": {
				"from": 373920,
				"to": 379100
			},
			"text": "而是整个店铺的综合数据也就是我们数据概览里面的总的数据"
		},
		{
			"timestamps": {
				"from": "00:06:19,100",
				"to": "00:06:21,240"
			},
			"offsets": {
				"from": 379100,
				"to": 381240
			},
			"text": "那么这些维度如果存在的问题"
		},
		{
			"timestamps": {
				"from": "00:06:21,240",
				"to": "00:06:24,800"
			},
			"offsets": {
				"from": 381240,
				"to": 384800
			},
			"text": "那么你在拆分比如说点击率出现问题"
		},
		{
			"timestamps": {
				"from": "00:06:24,800",
				"to": "00:06:27,780"
			},
			"offsets": {
				"from": 384800,
				"to": 387780
			},
			"text": "那么你是不是刚才上面这个是店铺综合数据"
		},
		{
			"timestamps": {
				"from": "00:06:27,780",
				"to": "00:06:29,980"
			},
			"offsets": {
				"from": 387780,
				"to": 389980
			},
			"text": "你是不是要去找到产品"
		},
		{
			"timestamps": {
				"from": "00:06:29,980",
				"to": "00:06:33,300"
			},
			"offsets": {
				"from": 389980,
				"to": 393300
			},
			"text": "哪些产品影响了这个店铺里面的综合数据"
		},
		{
			"timestamps": {
				"from": "00:06:33,300",
				"to": "00:06:35,860"
			},
			"offsets": {
				"from": 393300,
				"to": 395860
			},
			"text": "那么这个产品是否有推广"
		},
		{
			"timestamps": {
				"from": "00:06:35,860",
				"to": "00:06:39,260"
			},
			"offsets": {
				"from": 395860,
				"to": 399260
			},
			"text": "推广了是不是你要去找到对应的计划去进行优化"
		},
		{
			"timestamps": {
				"from": "00:06:39,260",
				"to": "00:06:43,440"
			},
			"offsets": {
				"from": 399260,
				"to": 403440
			},
			"text": "你看这些维度都是从大范围到小范围"
		},
		{
			"timestamps": {
				"from": "00:06:43,440",
				"to": "00:06:47,960"
			},
			"offsets": {
				"from": 403440,
				"to": 407960
			},
			"text": "再缩减到啥小范围, 这样去找问题, 就能够快速的找到问题了"
		},
		{
			"timestamps": {
				"from": "00:06:47,960",
				"to": "00:06:52,680"
			},
			"offsets": {
				"from": 407960,
				"to": 412680
			},
			"text": "关于这个直通车综合数据分析, 我们在直通车课程已经讲过了"
		},
		{
			"timestamps": {
				"from": "00:06:52,680",
				"to": "00:06:56,280"
			},
			"offsets": {
				"from": 412680,
				"to": 416280
			},
			"text": "那么你就根据那里面的方法去学习就可以了"
		},
		{
			"timestamps": {
				"from": "00:06:56,280",
				"to": "00:07:04,960"
			},
			"offsets": {
				"from": 416280,
				"to": 424960
			},
			"text": "第二个就是判断, 点击到访客量, 这个数据, 我们要通过访问点击笔去判断"
		},
		{
			"timestamps": {
				"from": "00:07:04,960",
				"to": "00:07:10,960"
			},
			"offsets": {
				"from": 424960,
				"to": 430960
			},
			"text": "为什么要判断这个数据呢? 因为这个数据大小就决定着我们店铺"
		},
		{
			"timestamps": {
				"from": "00:07:10,960",
				"to": "00:07:13,480"
			},
			"offsets": {
				"from": 430960,
				"to": 433480
			},
			"text": "当前自然流量的增长情况"
		},
		{
			"timestamps": {
				"from": "00:07:13,480",
				"to": "00:07:15,440"
			},
			"offsets": {
				"from": 433480,
				"to": 435440
			},
			"text": "这个数据越大"
		},
		{
			"timestamps": {
				"from": "00:07:15,440",
				"to": "00:07:20,220"
			},
			"offsets": {
				"from": 435440,
				"to": 440220
			},
			"text": "那么说明我们整个店铺的自然流量是在增长的"
		},
		{
			"timestamps": {
				"from": "00:07:20,220",
				"to": "00:07:21,940"
			},
			"offsets": {
				"from": 440220,
				"to": 441940
			},
			"text": "如果你越来越小就相当于"
		},
		{
			"timestamps": {
				"from": "00:07:21,940",
				"to": "00:07:24,980"
			},
			"offsets": {
				"from": 441940,
				"to": 444980
			},
			"text": "你很多都是靠那些搜索流量"
		},
		{
			"timestamps": {
				"from": "00:07:24,980",
				"to": "00:07:28,880"
			},
			"offsets": {
				"from": 444980,
				"to": 448880
			},
			"text": "或者是说靠直动车搜索点击来的那些访客"
		},
		{
			"timestamps": {
				"from": "00:07:28,880",
				"to": "00:07:30,660"
			},
			"offsets": {
				"from": 448880,
				"to": 450660
			},
			"text": "所以说就没有自然流量"
		},
		{
			"timestamps": {
				"from": "00:07:30,660",
				"to": "00:07:31,580"
			},
			"offsets": {
				"from": 450660,
				"to": 451580
			},
			"text": "没有自然流量的话"
		},
		{
			"timestamps": {
				"from": "00:07:31,580",
				"to": "00:07:33,400"
			},
			"offsets": {
				"from": 451580,
				"to": 453400
			},
			"text": "你的直动车成本就会越来越高"
		},
		{
			"timestamps": {
				"from": "00:07:33,400",
				"to": "00:07:34,600"
			},
			"offsets": {
				"from": 453400,
				"to": 454600
			},
			"text": "这是一个维度"
		},
		{
			"timestamps": {
				"from": "00:07:34,600",
				"to": "00:07:37,200"
			},
			"offsets": {
				"from": 454600,
				"to": 457200
			},
			"text": "那么如果你的曝光点击访客"
		},
		{
			"timestamps": {
				"from": "00:07:37,200",
				"to": "00:07:39,600"
			},
			"offsets": {
				"from": 457200,
				"to": 459600
			},
			"text": "这边这个板块没什么问题的时候"
		},
		{
			"timestamps": {
				"from": "00:07:39,600",
				"to": "00:08:08,960"
			},
			"offsets": {
				"from": 459600,
				"to": 488960
			},
			"text": "那么我们就要考虑, 访客量非常多, 为什么没有循环, 这时候我们就要去看我们的整体的循环转化率, 循环转化率就是循环出于访客, 那么我们一定要去参考行业的数据来进行对比, 大部分行业都是在6%到10%的转化率, 周秀的大多数都在12%以上, 但是呢, 并不代表这个是固定的数据啊, 因为有些行业它是比较低的, 那么那种情况,"
		},
		{
			"timestamps": {
				"from": "00:08:08,960",
				"to": "00:08:38,800"
			},
			"offsets": {
				"from": 488960,
				"to": 518800
			},
			"text": "你就要去参考整个行业的数据就可以了, 不一定要参考这里的数据, 询盘来了, 这些的问题也解决了, 但是它有订单, 为什么他们有订单呢, 那你就要看它的订单转化率怎么样, 跟别的行业差距有多大, 如果是差距很大的话, 那么我们没有订单时候是不是要反过来去解决询盘的质量问题, 以及询盘的精准度问题, 是不是就回到了我们之前所说的那些具体的方法,"
		},
		{
			"timestamps": {
				"from": "00:08:38,960",
				"to": "00:09:07,600"
			},
			"offsets": {
				"from": 518960,
				"to": 547600
			},
			"text": "去操作就行了,所以说我们如果你要去分析整个店铺的时候, 你就要从大的维度去看, 先看我们的综合数据, 流量是否存在问题, 转化是否存在问题, 订单是否存在问题, 如果这个不存在问题, 那么就直接跳到这个转化问题, 转化不存在问题, 那么就跳到这个订单问题, 如果订单这个板块出现问题的话, 肯定就是会跟上一个环节, 也就是说你的寻盘问题有关的,"
		},
		{
			"timestamps": {
				"from": "00:09:07,840",
				"to": "00:09:37,820"
			},
			"offsets": {
				"from": 547840,
				"to": 577820
			},
			"text": "如果你的试盘出现问题, 那么可能就比前面这个板块有相关性的, 所以我们是根据不同的维度去找到我们店铺当前处在哪个阶段的哪个问题, 然后再针对这些指标来进行去判断它是否落在合理的区间, 如果它落在合理的区间, 那么我们是不需要去做太大的调整的, 如果它比这些维度都低而低,"
		},
		{
			"timestamps": {
				"from": "00:09:37,820",
				"to": "00:10:07,800"
			},
			"offsets": {
				"from": 577820,
				"to": 607800
			},
			"text": "很多数据, 那么这个时候我们一定是需要去进行调整跟优化的, 你看我们从上面这里已经把这个店铺维度分析了之后, 店铺里面的整体的维度分析了之后, 店铺里面是不是有产品构成, 有产品一, 产品二, 产品三, 有大量的产品组成是不是, 店铺存在问题, 肯定反馈出来的, 产品里面肯定存在问题, 产品里面存在问题, 产品里面存在问题, 你看, 店铺存在问题, 你看, 店铺存在问题, 你看, 店铺存在问题,"
		},
		{
			"timestamps": {
				"from": "00:10:07,820",
				"to": "00:10:37,800"
			},
			"offsets": {
				"from": 607820,
				"to": 637800
			},
			"text": "那问题之后, 我们就要到产品去, 找问题, 那么产品找问题, 怎么找问题呢? 我们前面讲过, 产品优化, 产品分析, 这些板块都讲过了, 那么你就要去找对应的产品, 特别是优先考虑那种爆品, 实力优品, 它们的数据的变化, 这种产品数据的变化, 才是最直接影响整个店铺的效果了, 所以优先考虑爆品跟实力品, 那么"
		},
		{
			"timestamps": {
				"from": "00:10:37,820",
				"to": "00:11:06,960"
			},
			"offsets": {
				"from": 637820,
				"to": 666960
			},
			"text": "爆品跟实力品找到了是不是你在用直动车在推广呢, 如果你用直动车推广, 是不是能够针对这个计划里面去调整这些产品, 或者是调整你推广的一些指标, 来提升这些产品的效果, 是不是就能够倒推过来, 反作用于我们整个店铺, 所以我们找问题的时候都是从大的范围, 再缩减到小的范围, 然后解决具体的某个产品的问题, 或者是某个指标的问题,"
		},
		{
			"timestamps": {
				"from": "00:11:07,280",
				"to": "00:11:37,080"
			},
			"offsets": {
				"from": 667280,
				"to": 697080
			},
			"text": "那么你这个店铺才能够真正的解决问题, 这个就是关于我们整个店铺的一个诊断的一个整体的框架, 这里面有一个核心的一个流程, 加上判断的指标, 加上它具体的一个参考判断的数值, 再加上一个你要遵循这个流程去缩减, 去查找问题, 那么你最终才能够找到问题去解决就可以了, 那么这个店铺诊断框架我们就讲到这里, 希望这个诊断框架能够帮你"
		},
		{
			"timestamps": {
				"from": "00:11:37,080",
				"to": "00:11:44,400"
			},
			"offsets": {
				"from": 697080,
				"to": 704400
			},
			"text": "可以梳理你自己的一个知识体系, 能够帮助你在后期的诊断中快速地找到问题, 解决问题"
		},
		{
			"timestamps": {
				"from": "00:11:44,400",
				"to": "00:11:47,740"
			},
			"offsets": {
				"from": 704400,
				"to": 707740
			},
			"text": "那么这节课我们就先讲到这里, 下节课我们再见"
		}
	]
}
