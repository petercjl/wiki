			},
			"offsets": {
				"from": 57460,
				"to": 64400
			},
			"text": "第二个维度是根据我们自己店铺里面的店铺的综合数据的细节等维度去进行分析"
		},
		{
			"timestamps": {
				"from": "00:01:04,400",
