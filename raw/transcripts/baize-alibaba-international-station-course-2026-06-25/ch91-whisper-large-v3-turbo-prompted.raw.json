				"to": "00:04:26,660"
			},
			"offsets": {
				"from": 261120,
				"to": 266660
			},
			"text": "是不是说明你们的店铺标签混乱且不精准 巡盘质量差"
		},
		{
			"timestamps": {
				"from": "00:04:26,660",
				"to": "00:04:30,160"
			},
			"offsets": {
				"from": 266660,
				"to": 270160
			},
			"text": "巡盘质量差就是导致订单转化非常的低"
