				"to": "00:02:20,700"
			},
			"offsets": {
				"from": 137860,
				"to": 140700
			},
			"text": "或者是公司现在处于什么阶段"
		},
		{
			"timestamps": {
				"from": "00:02:20,700",
				"to": "00:02:22,540"
			},
			"offsets": {
				"from": 140700,
				"to": 142540
			},
			"text": "这个一定要去掌握这个"
		},
		{
			"timestamps": {
				"from": "00:02:22,540",
				"to": "00:02:31,460"
			},
			"offsets": {
				"from": 142540,
				"to": 151460
			},
			"text": "因为很多人 其实他不关注这个 也不关注这些 他就总是围绕着 好像自己操作的技能很强"
		},
		{
			"timestamps": {
				"from": "00:02:31,460",
