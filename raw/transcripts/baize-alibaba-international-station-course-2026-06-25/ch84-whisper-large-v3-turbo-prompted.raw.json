				"from": "00:08:39,200",
				"to": "00:08:42,200"
			},
			"offsets": {
				"from": 519200,
				"to": 522200
			},
			"text": "那么可以直接放弃这些老产品"
		},
		{
			"timestamps": {
				"from": "00:08:42,200",
				"to": "00:08:45,200"
			},
			"offsets": {
				"from": 522200,
				"to": 525200
			},
			"text": "我重新发品重新去推广"
		},
