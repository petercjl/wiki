				"from": "00:06:33,200",
				"to": "00:06:35,200"
			},
			"offsets": {
				"from": 393200,
				"to": 395200
			},
			"text": "第一个就是新发的产品"
		},
		{
			"timestamps": {
				"from": "00:06:35,200",
				"to": "00:06:37,200"
			},
			"offsets": {
				"from": 395200,
				"to": 397200
			},
			"text": "直接用新品加速计划去推广"
		},
		{
			"timestamps": {
				"from": "00:06:37,200",
				"to": "00:06:39,200"
			},
			"offsets": {
				"from": 397200,
				"to": 399200
			},
			"text": "比如说我们刚才这里已经发了"
		},
		{
			"timestamps": {
				"from": "00:06:39,200",
				"to": "00:06:42,200"
			},
			"offsets": {
				"from": 399200,
				"to": 402200
			},
			"text": "单一品内可能发了20-50个链接"
		},
		{
			"timestamps": {
				"from": "00:06:42,200",
				"to": "00:06:45,200"
			},
			"offsets": {
				"from": 402200,
				"to": 405200
			},
			"text": "那么你直接用新品加速计划"
		},
		{
			"timestamps": {
				"from": "00:06:45,200",
				"to": "00:06:48,200"
			},
			"offsets": {
				"from": 405200,
				"to": 408200
			},
			"text": "一次性推20-50个链接"
		},
		{
			"timestamps": {
				"from": "00:06:48,200",
				"to": "00:06:50,200"
			},
			"offsets": {
				"from": 408200,
				"to": 410200
			},
			"text": "第二个它的预算"
		},
		{
			"timestamps": {
				"from": "00:06:50,200",
				"to": "00:06:52,200"
			},
			"offsets": {
				"from": 410200,
				"to": 412200
			},
			"text": "你可以设置到100-200左右"
		},
		{
			"timestamps": {
				"from": "00:06:52,200",
				"to": "00:06:54,200"
			},
			"offsets": {
				"from": 412200,
				"to": 414200
			},
			"text": "第三个就是刚才我们讲了"
		},
		{
			"timestamps": {
				"from": "00:06:54,200",
				"to": "00:06:57,200"
			},
			"offsets": {
				"from": 414200,
				"to": 417200
			},
			"text": "其实就是说的它的产品的数量"
		},
		{
			"timestamps": {
				"from": "00:06:57,200",
				"to": "00:06:58,200"
			},
			"offsets": {
				"from": 417200,
				"to": 418200
			},
			"text": "就是50个以内"
		},
		{
			"timestamps": {
				"from": "00:06:58,200",
				"to": "00:07:00,200"
			},
			"offsets": {
				"from": 418200,
				"to": 420200
			},
			"text": "第四个就是两周内找到潜力的链接"
		},
		{
			"timestamps": {
				"from": "00:07:00,200",
				"to": "00:07:03,200"
			},
			"offsets": {
				"from": 420200,
				"to": 423200
			},
			"text": "也就是从这个新品计划里面的20-50个链接"
		},
		{
			"timestamps": {
				"from": "00:07:03,200",
				"to": "00:07:06,200"
			},
			"offsets": {
				"from": 423200,
				"to": 426200
			},
			"text": "也就是从这个新品计划里面的20-50个链接"
		},
		{
			"timestamps": {
				"from": "00:07:06,200",
				"to": "00:07:09,200"
			},
			"offsets": {
				"from": 426200,
				"to": 429200
			},
			"text": "里面找到至少10个左右的潜力链接"
		},
		{
			"timestamps": {
				"from": "00:07:09,200",
				"to": "00:07:11,200"
			},
			"offsets": {
				"from": 429200,
				"to": 431200
			},
			"text": "第五步就是综合的应用指动车"
		},
		{
			"timestamps": {
				"from": "00:07:11,200",
				"to": "00:07:13,200"
			},
			"offsets": {
				"from": 431200,
				"to": 433200
			},
			"text": "比如说你这10个链接"
		},
		{
			"timestamps": {
				"from": "00:07:13,200",
				"to": "00:07:15,200"
			},
			"offsets": {
				"from": 433200,
				"to": 435200
			},
			"text": "是不是继续在新品加速里面推广"
		},
		{
			"timestamps": {
				"from": "00:07:15,200",
				"to": "00:07:21,200"
			},
			"offsets": {
				"from": 435200,
				"to": 441200
			},
			"text": "或者是我部分的产品已经移动到泡品就推"
		},
		{
			"timestamps": {
				"from": "00:07:21,200",
				"to": "00:07:26,200"
			},
			"offsets": {
				"from": 441200,
				"to": 446200
			},
			"text": "关键值推广等等这些新的关键值的计划去辅助"
