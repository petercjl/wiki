			"timestamps": {
				"from": "00:07:56,200",
				"to": "00:08:00,200"
			},
			"offsets": {
				"from": 476200,
				"to": 480200
			},
			"text": "那么这个选品可能只需要三天"
		},
		{
			"timestamps": {
				"from": "00:08:00,200",
				"to": "00:08:04,200"
			},
			"offsets": {
				"from": 480200,
				"to": 484200
			},
			"text": "那么精细化标题可能需要五天三到五天"
