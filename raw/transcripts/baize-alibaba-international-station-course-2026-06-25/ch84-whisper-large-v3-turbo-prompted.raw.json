				"from": "00:05:55,200",
				"to": "00:05:56,200"
			},
			"offsets": {
				"from": 355200,
				"to": 356200
			},
			"text": "同时呢"
		},
		{
			"timestamps": {
				"from": "00:05:56,200",
				"to": "00:05:58,200"
			},
			"offsets": {
				"from": 356200,
				"to": 358200
			},
			"text": "他有些产品效果非常好"
		},
		{
			"timestamps": {
				"from": "00:05:58,200",
				"to": "00:05:59,200"
			},
			"offsets": {
				"from": 358200,
				"to": 359200
			},
			"text": "群盘多TM多"
		},
		{
			"timestamps": {
				"from": "00:05:59,200",
				"to": "00:06:00,200"
			},
			"offsets": {
				"from": 359200,
				"to": 360200
			},
			"text": "目标国家也精准"
		},
		{
			"timestamps": {
				"from": "00:06:00,200",
				"to": "00:06:02,200"
			},
			"offsets": {
				"from": 360200,
				"to": 362200
			},
			"text": "但是短期内可能是一个月内"
		},
		{
			"timestamps": {
				"from": "00:06:02,200",
				"to": "00:06:04,200"
			},
			"offsets": {
				"from": 362200,
				"to": 364200
			},
			"text": "可能这个订单谈不下来"
		},
		{
			"timestamps": {
				"from": "00:06:04,200",
				"to": "00:06:06,200"
			},
			"offsets": {
				"from": 364200,
				"to": 366200
			},
			"text": "所以说他订单量就少"
		},
		{
			"timestamps": {
				"from": "00:06:06,200",
				"to": "00:06:10,200"
			},
			"offsets": {
				"from": 366200,
				"to": 370200
			},
			"text": "如果这个时候你你不去用一些老客户的"
		},
		{
			"timestamps": {
				"from": "00:06:10,200",
				"to": "00:06:13,200"
			},
			"offsets": {
				"from": 370200,
				"to": 373200
			},
			"text": "订单去绑定这些新的产品"
		},
		{
			"timestamps": {
				"from": "00:06:13,200",
				"to": "00:06:16,200"
			},
			"offsets": {
				"from": 373200,
				"to": 376200
			},
			"text": "那么你这些新的产品也很难起来"
		},
		{
			"timestamps": {
				"from": "00:06:16,200",
				"to": "00:06:19,200"
			},
			"offsets": {
				"from": 376200,
				"to": 379200
			},
			"text": "因为他中间有一个订单的转化率"
		},
		{
			"timestamps": {
				"from": "00:06:19,200",
				"to": "00:06:21,200"
			},
			"offsets": {
				"from": 379200,
				"to": 381200
			},
			"text": "还有巡盘的转化率"
		},
		{
			"timestamps": {
				"from": "00:06:21,200",
				"to": "00:06:22,200"
			},
			"offsets": {
				"from": 381200,
				"to": 382200
			},
			"text": "订单转化率太低的话"
		},
		{
			"timestamps": {
				"from": "00:06:22,200",
				"to": "00:06:25,200"
			},
			"offsets": {
				"from": 382200,
				"to": 385200
			},
			"text": "那么平台就认为你的价值太少"
		},
		{
			"timestamps": {
				"from": "00:06:25,200",
				"to": "00:06:27,200"
			},
			"offsets": {
				"from": 385200,
				"to": 387200
			},
			"text": "给你推荐的流量就会下降"
		},
		{
			"timestamps": {
				"from": "00:06:27,200",
				"to": "00:06:31,200"
			},
			"offsets": {
				"from": 387200,
				"to": 391200
			},
			"text": "所以一定要注意这个订单的绑定"
		},
		{
			"timestamps": {
				"from": "00:06:31,200",
				"to": "00:06:33,200"
			},
			"offsets": {
				"from": 391200,
				"to": 393200
			},
			"text": "那么具体的操作怎么做呢"
		},
		{
