			"timestamps": {
				"from": "00:08:12,200",
				"to": "00:08:14,200"
			},
			"offsets": {
				"from": 492200,
				"to": 494200
			},
			"text": "你越早推广"
		},
		{
			"timestamps": {
				"from": "00:08:14,200",
				"to": "00:08:15,200"
			},
			"offsets": {
				"from": 494200,
				"to": 495200
			},
			"text": "对你来说越有利"
		},
		{
			"timestamps": {
				"from": "00:08:15,200",
				"to": "00:08:18,200"
			},
			"offsets": {
				"from": 495200,
				"to": 498200
			},
			"text": "推广的时候不一定说要那么多的预算"
		},
		{
			"timestamps": {
				"from": "00:08:18,200",
				"to": "00:08:23,200"
			},
			"offsets": {
				"from": 498200,
				"to": 503200
			},
			"text": "你至少50块钱都比没有推广的效果好"
