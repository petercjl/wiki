				"to": "00:08:48,200"
			},
			"offsets": {
				"from": 525200,
				"to": 528200
			},
			"text": "我把它当做一个新店去做"
		},
		{
			"timestamps": {
				"from": "00:08:48,200",
				"to": "00:08:51,200"
			},
			"offsets": {
				"from": 528200,
				"to": 531200
			},
			"text": "这样的话你的老店也很快就被盘活了"
		},
		{
			"timestamps": {
				"from": "00:08:51,200",
				"to": "00:08:54,200"
			},
			"offsets": {
				"from": 531200,
				"to": 534200
			},
			"text": "但是呢很多人陷入了一个常规的陷阱"
		},
		{
			"timestamps": {
				"from": "00:08:54,200",
				"to": "00:08:57,200"
			},
			"offsets": {
				"from": 534200,
				"to": 537200
			},
			"text": "很多人喜欢在老店铺里面"
		},
		{
			"timestamps": {
				"from": "00:08:57,200",
				"to": "00:08:59,200"
			},
			"offsets": {
				"from": 537200,
				"to": 539200
			},
			"text": "不断的去挑选产品"
		},
		{
			"timestamps": {
				"from": "00:08:59,200",
				"to": "00:09:00,200"
			},
			"offsets": {
				"from": 539200,
				"to": 540200
			},
			"text": "不断的去推广"
		},
		{
			"timestamps": {
				"from": "00:09:00,200",
				"to": "00:09:02,200"
			},
			"offsets": {
				"from": 540200,
				"to": 542200
			},
			"text": "你发现就是那些老产品"
		},
		{
			"timestamps": {
				"from": "00:09:02,200",
				"to": "00:09:03,200"
			},
			"offsets": {
				"from": 542200,
				"to": 543200
			},
			"text": "无论你怎么推"
		},
		{
			"timestamps": {
				"from": "00:09:03,200",
				"to": "00:09:04,200"
			},
			"offsets": {
				"from": 543200,
				"to": 544200
			},
			"text": "无论你怎么改"
		},
		{
			"timestamps": {
				"from": "00:09:04,200",
				"to": "00:09:06,200"
			},
			"offsets": {
				"from": 544200,
				"to": 546200
			},
			"text": "它的效果都是非常差的"
		},
		{
			"timestamps": {
				"from": "00:09:06,200",
				"to": "00:09:10,200"
			},
			"offsets": {
				"from": 546200,
				"to": 550200
			},
			"text": "或者是说效果的提升都是非常慢的"
		},
		{
			"timestamps": {
				"from": "00:09:10,200",
				"to": "00:09:12,200"
			},
			"offsets": {
				"from": 550200,
				"to": 552200
			},
			"text": "那么这个对于你来说"
		},
		{
