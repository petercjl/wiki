			"timestamps": {
				"from": "00:07:33,200",
				"to": "00:07:38,200"
			},
			"offsets": {
				"from": 453200,
				"to": 458200
			},
			"text": "前期我们把一到三个品类的流量已经做起来之后"
		},
		{
			"timestamps": {
				"from": "00:07:38,200",
				"to": "00:07:43,200"
			},
			"offsets": {
				"from": 458200,
				"to": 463200
			},
			"text": "后续我们可以通过拓品类来增加整个店铺的总流量"
