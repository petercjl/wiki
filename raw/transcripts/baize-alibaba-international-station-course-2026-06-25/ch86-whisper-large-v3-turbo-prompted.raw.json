				"to": 365400
			},
			"text": "特定商品也就是说指定你店铺里面哪些商品可以用这个满折券 哪些不可以用"
		},
		{
			"timestamps": {
				"from": "00:06:05,400",
				"to": "00:06:10,400"
			},
			"offsets": {
				"from": 365400,
				"to": 370400
			},
			"text": "要么你就选全店 全店的话 那么整个店铺都可以用 无论你是"
		},
		{
			"timestamps": {
				"from": "00:06:10,400",
				"to": "00:06:14,400"
			},
			"offsets": {
				"from": 370400,
				"to": 374400
			},
			"text": "无论你是定制产品还是RTS产品都可以应用"
		},
		{
			"timestamps": {
				"from": "00:06:14,400",
				"to": "00:06:20,400"
			},
			"offsets": {
				"from": 374400,
				"to": 380400
			},
			"text": "那么这里就是立即发布创建就可以了 创建了之后他就会马上生效了"
		},
		{
			"timestamps": {
				"from": "00:06:20,400",
				"to": "00:06:26,400"
			},
			"offsets": {
				"from": 380400,
				"to": 386400
			},
			"text": "但是这个折扣券的话设置的不是马上生效的 它是第二天才生效的"
		},
		{
			"timestamps": {
				"from": "00:06:26,400",
				"to": "00:06:33,400"
			},
			"offsets": {
				"from": 386400,
				"to": 393400
			},
			"text": "所以说你一定要如果你想明天活动开始 那么你今天就要提前设置好这个折扣营销"
		},
		{
			"timestamps": {
				"from": "00:06:33,400",
				"to": "00:06:38,400"
			},
			"offsets": {
				"from": 393400,
				"to": 398400
			},
			"text": "设置了这些折扣营销 对我们有什么好处呢 比如说我们来看一下"
		},
		{
			"timestamps": {
				"from": "00:06:38,400",
				"to": "00:06:44,400"
			},
			"offsets": {
				"from": 398400,
				"to": 404400
			},
			"text": "比如说像这些自营销 如果我们设置了自营销 是不是这个产品"
		},
		{
			"timestamps": {
				"from": "00:06:44,400",
				"to": "00:06:49,400"
			},
			"offsets": {
				"from": 404400,
				"to": 409400
			},
			"text": "这里就有这些折扣的信息 是不是更加有吸引力"
		},
		{
			"timestamps": {
				"from": "00:06:49,400",
				"to": "00:06:54,400"
			},
			"offsets": {
				"from": 409400,
				"to": 414400
			},
			"text": "还有另一个就是我们如果设置了优惠券 我们看一下优惠券"
		},
		{
			"timestamps": {
				"from": "00:06:54,400",
				"to": "00:06:59,400"
			},
			"offsets": {
				"from": 414400,
				"to": 419400
			},
			"text": "比如说我们设置了优惠券 那么这里就会有优惠券 是吧"
		},
		{
			"timestamps": {
				"from": "00:06:59,400",
				"to": "00:07:04,400"
			},
			"offsets": {
				"from": 419400,
				"to": 424400
			},
			"text": "这产品就有优惠券 因为这个产品已经加入了优惠券这个板块"
		},
		{
			"timestamps": {
				"from": "00:07:04,400",
				"to": "00:07:09,400"
			},
			"offsets": {
				"from": 424400,
				"to": 429400
			},
			"text": "所以说就会在这里有优惠券 或者是你在这里又有折扣 看到没有"
		},
		{
			"timestamps": {
				"from": "00:07:09,400",
				"to": "00:07:14,400"
			},
			"offsets": {
				"from": 429400,
				"to": 434400
			},
			"text": "是不是更加具有吸引力 而且当客户领你这个券的时候"
		},
		{
			"timestamps": {
				"from": "00:07:14,400",
				"to": "00:07:16,400"
			},
			"offsets": {
				"from": 434400,
				"to": 436400
			},
			"text": "那么它是不是可以进到你的店铺"
		},
		{
			"timestamps": {
				"from": "00:07:16,400",
				"to": "00:07:19,400"
			},
			"offsets": {
				"from": 436400,
				"to": 439400
			},
			"text": "这些是不是都能够增加客户停留"
		},
		{
			"timestamps": {
				"from": "00:07:19,400",
				"to": "00:07:24,400"
			},
			"offsets": {
				"from": 439400,
				"to": 444400
			},
			"text": "还有另一个就是如果我们在参加了整体的活动"
		},
		{
			"timestamps": {
				"from": "00:07:24,400",
				"to": "00:07:30,400"
			},
			"offsets": {
				"from": 444400,
				"to": 450400
			},
			"text": "比如说我们看一下首页 我们参加了官方的会采购这个活动"
		},
		{
			"timestamps": {
				"from": "00:07:30,400",
				"to": "00:07:36,400"
			},
			"offsets": {
				"from": 450400,
				"to": 456400
			},
			"text": "比如说我们参加了这个 那么你报名通过了 是不是他就在这个板块里面"
		},
		{
			"timestamps": {
				"from": "00:07:36,400",
				"to": "00:07:40,400"
			},
			"offsets": {
				"from": 456400,
				"to": 460400
			},
			"text": "就有很大的流量 这个板块流量是非常大的"
		},
		{
			"timestamps": {
				"from": "00:07:40,400",
				"to": "00:07:46,400"
			},
			"offsets": {
				"from": 460400,
				"to": 466400
			},
			"text": "所以说只要你的产品有条件 能够参加这个活动 并且通过了报名"
		},
		{
			"timestamps": {
				"from": "00:07:46,400",
				"to": "00:07:52,400"
			},
			"offsets": {
				"from": 466400,
				"to": 472400
			},
			"text": "那么它的流量一定会有一定的提升的 一定会有可能获得旋盘跟订单的"
		},
		{
			"timestamps": {
				"from": "00:07:52,400",
				"to": "00:07:57,400"
			},
			"offsets": {
				"from": 472400,
				"to": 477400
			},
			"text": "所以如果你是做RTS店铺的时候 一定要重视这些板块"
		},
		{
			"timestamps": {
				"from": "00:07:57,400",
				"to": "00:08:02,400"
			},
			"offsets": {
				"from": 477400,
				"to": 482400
			},
			"text": "这些板块都非常非常的重要 有很多人就说我是做定制内店铺的"
		},
		{
			"timestamps": {
				"from": "00:08:02,400",
				"to": "00:08:08,400"
			},
			"offsets": {
				"from": 482400,
				"to": 488400
			},
			"text": "其实定制内店铺的也可以有部分产品是需要发RTS"
		},
		{
			"timestamps": {
				"from": "00:08:08,400",
				"to": "00:08:13,400"
			},
			"offsets": {
				"from": 488400,
				"to": 493400
			},
			"text": "做几个常规的链接去专门的报名活动"
		},
		{
			"timestamps": {
				"from": "00:08:13,400",
				"to": "00:08:19,400"
			},
			"offsets": {
				"from": 493400,
				"to": 499400
			},
			"text": "同时参加一些活动 或者是自己设置一些营销折扣作为引流"
		},
		{
			"timestamps": {
				"from": "00:08:19,400",
				"to": "00:08:22,400"
			},
			"offsets": {
				"from": 499400,
				"to": 502400
			},
			"text": "这样的话更加有利于我们店铺全面的进行引流"
		},
		{
			"timestamps": {
				"from": "00:08:22,400",
				"to": "00:08:28,400"
			},
			"offsets": {
				"from": 502400,
				"to": 508400
			},
			"text": "另外一个就是如果我们设置了优惠活动 我们在这个这里"
		},
		{
			"timestamps": {
				"from": "00:08:28,400",
				"to": "00:08:33,400"
			},
			"offsets": {
				"from": 508400,
				"to": 513400
			},
			"text": "营销客户营销这里 是不是就能够有"
		},
		{
			"timestamps": {
				"from": "00:08:33,400",
				"to": "00:08:40,400"
			},
			"offsets": {
				"from": 513400,
				"to": 520400
			},
			"text": "优惠券被检锁到 那么我们是不是也可以在这些地方选择 选择你想要营销的客群模板"
		},
		{
			"timestamps": {
				"from": "00:08:40,400",
				"to": "00:08:47,400"
			},
			"offsets": {
				"from": 520400,
				"to": 527400
			},
			"text": "比如说我就预览一下 你看这些是不是有优惠券 所以说你一定要善于使用这些优惠券"
		},
		{
			"timestamps": {
				"from": "00:08:47,400",
				"to": "00:08:54,400"
			},
			"offsets": {
				"from": 527400,
				"to": 534400
			},
			"text": "还有另一个就是营销活动 我们来看一下 比如说我圈智能圈客 也就是我们所说的反客营销"
		},
		{
			"timestamps": {
				"from": "00:08:54,400",
				"to": "00:08:59,400"
			},
			"offsets": {
				"from": 534400,
				"to": 539400
			},
			"text": "你看这里是不是有 如果是你设置了优惠券 是不是就可以"
		},
		{
			"timestamps": {
				"from": "00:08:59,400",
				"to": "00:09:06,400"
			},
			"offsets": {
				"from": 539400,
				"to": 546400
			},
			"text": "它会自动添加到你的营销卡片里面 当客户看到的信息 然后发现有券的时候是不是会停留"
		},
		{
			"timestamps": {
				"from": "00:09:06,400",
				"to": "00:09:12,400"
			},
			"offsets": {
				"from": 546400,
				"to": 552400
			},
			"text": "或者是点击一下优惠券看看其他的产品是什么 是不是这样是不是都能够"
		},
		{
			"timestamps": {
				"from": "00:09:12,400",
				"to": "00:09:22,400"
			},
			"offsets": {
				"from": 552400,
				"to": 562400
			},
			"text": "让客户有更多停留的机会 所以这个板块一定要重视 重视起来 那么这个就是我们所说的官方活动"
		},
		{
			"timestamps": {
				"from": "00:09:22,400",
				"to": "00:09:27,400"
			},
			"offsets": {
				"from": 562400,
				"to": 567400
			},
			"text": "一定要报名 无论哪个 只要你满足了都要报名 折扣券 优惠券"
		},
		{
			"timestamps": {
				"from": "00:09:27,400",
				"to": "00:09:32,400"
			},
			"offsets": {
				"from": 567400,
				"to": 572400
			},
			"text": "如果官方没有这些活动的话 那么我们自己搞活动 一定要善于用"
		},
		{
			"timestamps": {
				"from": "00:09:32,400",
				"to": "00:09:38,400"
			},
			"offsets": {
				"from": 572400,
				"to": 578400
			},
			"text": "可以用于直播间 也可以用于日常的自动的推广 比如说你推广某些产品的时候"
		},
		{
			"timestamps": {
				"from": "00:09:38,400",
				"to": "00:09:44,400"
			},
			"offsets": {
				"from": 578400,
				"to": 584400
			},
			"text": "许马通话很差 是不是可以搭配一下优惠券或者是折扣券 尝试一下它的效果"
		},
		{
			"timestamps": {
				"from": "00:09:44,400",
				"to": "00:09:51,400"
			},
			"offsets": {
				"from": 584400,
				"to": 591400
			},
			"text": "这些都是可以的 有很多人觉得它的产品的价格本来就很低了 没有办法设置优惠券"
		},
		{
			"timestamps": {
				"from": "00:09:51,400",
				"to": "00:09:57,400"
			},
			"offsets": {
				"from": 591400,
				"to": 597400
			},
			"text": "那么那么你如果你想优惠券设置不了 你可以设置折扣券 折扣券的话"
		},
		{
			"timestamps": {
				"from": "00:09:57,400",
				"to": "00:10:04,400"
			},
			"offsets": {
				"from": 597400,
				"to": 604400
			},
			"text": "最低是我们可以95折或者是9折 这些产品呢 虽然设置优惠券可能会亏本 是吧"
		},
		{
			"timestamps": {
				"from": "00:10:04,400",
				"to": "00:10:10,400"
			},
			"offsets": {
				"from": 604400,
				"to": 610400
			},
			"text": "那么我们可以在产品详情页里面去把它的尺寸"
		},
		{
			"timestamps": {
				"from": "00:10:10,400",
				"to": "00:10:16,400"
			},
			"offsets": {
				"from": 610400,
				"to": 616400
			},
			"text": "跟它的重量稍微调整一点点 那么它的整体的物流费用可能就会增加一点点"
		},
		{
			"timestamps": {
				"from": "00:10:16,400",
				"to": "00:10:22,400"
			},
			"offsets": {
				"from": 616400,
				"to": 622400
			},
			"text": "但是呢 它能够帮你有效的降低你亏损 或者至少你这个产品是不亏本的"
		},
		{
			"timestamps": {
				"from": "00:10:22,400",
				"to": "00:10:28,400"
			},
			"offsets": {
				"from": 622400,
				"to": 628400
			},
			"text": "那么这个时候 客户看到的物流 其实它没有那么感受那么深的值"
		},
		{
			"timestamps": {
				"from": "00:10:28,400",
				"to": "00:10:34,400"
			},
			"offsets": {
				"from": 628400,
				"to": 634400
			},
			"text": "如果是它多一点点的物流费用 它是体会不到的 或者是说感受不"
		},
		{
			"timestamps": {
				"from": "00:10:34,400",
				"to": "00:10:38,400"
			},
			"offsets": {
				"from": 634400,
				"to": 638400
			},
			"text": "没有那么明显区分的 所以这个板块要善于利用起来"
		},
		{
			"timestamps": {
				"from": "00:10:38,400",
				"to": "00:10:46,400"
			},
			"offsets": {
				"from": 638400,
				"to": 646400
			},
			"text": "特别是在我们的产品详情页中 有折扣券跟没有折扣券的区别是很大的"
		},
		{
			"timestamps": {
				"from": "00:10:46,400",
				"to": "00:10:53,400"
			},
			"offsets": {
				"from": 646400,
				"to": 653400
			},
			"text": "如果你是做现货的一定要用上 如果是你做定制的 那么你店铺里面的定制产品可以设置"
		},
		{
			"timestamps": {
				"from": "00:10:53,400",
				"to": "00:10:59,400"
			},
			"offsets": {
				"from": 653400,
				"to": 659400
			},
			"text": "优惠券这些都可以作为一个引流 因为在我们的店铺首页还是可以展示出来的"
		},
		{
			"timestamps": {
				"from": "00:10:59,400",
				"to": "00:10:59,980"
			},
			"offsets": {
				"from": 659400,
				"to": 659980
			},
			"text": "不然"
		}
	]
}
