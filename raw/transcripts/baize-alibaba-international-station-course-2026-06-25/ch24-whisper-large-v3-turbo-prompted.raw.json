				"to": 544280
			},
			"text": "我们直接打开了店铺之后"
		},
		{
			"timestamps": {
				"from": "00:09:04,280",
				"to": "00:09:07,600"
			},
			"offsets": {
				"from": 544280,
				"to": 547600
			},
			"text": "我们进入到他的产品分组这里面"
		},
		{
			"timestamps": {
				"from": "00:09:07,600",
				"to": "00:09:08,880"
			},
			"offsets": {
				"from": 547600,
				"to": 548880
			},
			"text": "你看他是不是"
		},
		{
			"timestamps": {
				"from": "00:09:08,880",
				"to": "00:09:11,440"
			},
			"offsets": {
				"from": 548880,
				"to": 551440
			},
			"text": "已经给我们分好的产品了"
		},
		{
			"timestamps": {
				"from": "00:09:11,440",
				"to": "00:09:14,520"
			},
			"offsets": {
				"from": 551440,
				"to": 554520
			},
			"text": "你看他这个是不是已经给我们分好了"
		},
		{
			"timestamps": {
				"from": "00:09:14,520",
				"to": "00:09:16,300"
			},
			"offsets": {
				"from": 554520,
				"to": 556300
			},
			"text": "我们直接点进去看"
		},
		{
			"timestamps": {
				"from": "00:09:16,300",
				"to": "00:09:18,360"
			},
			"offsets": {
				"from": 556300,
				"to": 558360
			},
			"text": "他们的这些是哪些产品"
		},
		{
			"timestamps": {
				"from": "00:09:18,360",
				"to": "00:09:20,400"
			},
			"offsets": {
				"from": 558360,
				"to": 560400
			},
			"text": "我们根据他的产品去选择"
		},
		{
			"timestamps": {
				"from": "00:09:20,400",
				"to": "00:09:22,960"
			},
			"offsets": {
				"from": 560400,
				"to": 562960
			},
			"text": "或者是根据他们的产品去看"
		},
		{
			"timestamps": {
				"from": "00:09:22,960",
				"to": "00:09:25,000"
			},
			"offsets": {
				"from": 562960,
				"to": 565000
			},
			"text": "我们跟他的差距是多大"
		},
		{
			"timestamps": {
				"from": "00:09:25,000",
				"to": "00:09:26,800"
			},
			"offsets": {
				"from": 565000,
				"to": 566800
			},
			"text": "是不是他已经帮我们分裂好了"
		},
		{
			"timestamps": {
				"from": "00:09:26,800",
				"to": "00:09:27,560"
			},
			"offsets": {
				"from": 566800,
				"to": 567560
			},
			"text": "你看点进去"
		},
		{
			"timestamps": {
				"from": "00:09:27,560",
				"to": "00:09:29,360"
			},
			"offsets": {
				"from": 567560,
				"to": 569360
			},
			"text": "点进去就是这些产品"
		},
		{
			"timestamps": {
				"from": "00:09:29,360",
				"to": "00:09:30,120"
			},
			"offsets": {
				"from": 569360,
				"to": 570120
			},
			"text": "你看这些产品"
		},
		{
			"timestamps": {
				"from": "00:09:30,120",
				"to": "00:09:31,660"
			},
			"offsets": {
				"from": 570120,
				"to": 571660
			},
			"text": "款式风格"
		},
		{
			"timestamps": {
				"from": "00:09:31,660",
				"to": "00:09:32,680"
			},
			"offsets": {
				"from": 571660,
				"to": 572680
			},
			"text": "无论你是"
		},
		{
			"timestamps": {
				"from": "00:09:32,680",
				"to": "00:09:33,960"
			},
			"offsets": {
				"from": 572680,
				"to": 573960
			},
			"text": "热门还是冷门"
		},
		{
			"timestamps": {
				"from": "00:09:33,960",
				"to": "00:09:35,240"
			},
			"offsets": {
				"from": 573960,
				"to": 575240
			},
			"text": "都可以用这个方法"
		},
		{
			"timestamps": {
				"from": "00:09:35,240",
				"to": "00:09:36,020"
			},
			"offsets": {
				"from": 575240,
				"to": 576020
			},
			"text": "因为"
		},
		{
			"timestamps": {
				"from": "00:09:36,020",
				"to": "00:09:38,320"
			},
			"offsets": {
				"from": 576020,
				"to": 578320
			},
			"text": "很多人他去外面学习的时候"
		},
		{
			"timestamps": {
				"from": "00:09:38,320",
				"to": "00:09:41,400"
			},
			"offsets": {
				"from": 578320,
				"to": 581400
			},
			"text": "他学到的方法就是按照这个分组"
		},
		{
			"timestamps": {
				"from": "00:09:41,400",
				"to": "00:09:43,960"
			},
			"offsets": {
				"from": 581400,
				"to": 583960
			},
			"text": "那么他肯定是像某个老师学的"
		},
		{
			"timestamps": {
				"from": "00:09:43,960",
				"to": "00:09:45,480"
			},
			"offsets": {
				"from": 583960,
				"to": 585480
			},
			"text": "如果是按照分组吧"
		},
		{
			"timestamps": {
				"from": "00:09:45,480",
				"to": "00:09:49,080"
			},
			"offsets": {
				"from": 585480,
				"to": 589080
			},
			"text": "那么他就给我们已经提供了最好的分考方向了"
		},
		{
			"timestamps": {
				"from": "00:09:49,080",
				"to": "00:09:50,100"
			},
			"offsets": {
				"from": 589080,
				"to": 590100
			},
			"text": "所以说"
		},
		{
			"timestamps": {
				"from": "00:09:50,100",
				"to": "00:09:52,140"
			},
			"offsets": {
				"from": 590100,
				"to": 592140
			},
			"text": "你只要去选得到"
		},
		{
			"timestamps": {
				"from": "00:09:52,140",
				"to": "00:09:54,700"
			},
			"offsets": {
				"from": 592140,
				"to": 594700
			},
			"text": "你那个行业优秀的店铺"
		},
		{
			"timestamps": {
				"from": "00:09:54,700",
				"to": "00:09:57,000"
			},
			"offsets": {
				"from": 594700,
				"to": 597000
			},
			"text": "把他的几个链接保存下来"
		},
		{
			"timestamps": {
				"from": "00:09:57,000",
				"to": "00:09:58,800"
			},
			"offsets": {
				"from": 597000,
				"to": 598800
			},
			"text": "每周每月都去看一下"
		},
		{
			"timestamps": {
				"from": "00:09:58,800",
				"to": "00:10:00,340"
			},
			"offsets": {
				"from": 598800,
				"to": 600340
			},
			"text": "那么你的选品"
		},
		{
			"timestamps": {
				"from": "00:10:00,340",
				"to": "00:10:01,360"
			},
			"offsets": {
				"from": 600340,
				"to": 601360
			},
			"text": "以及"
		},
		{
			"timestamps": {
				"from": "00:10:01,360",
				"to": "00:10:03,660"
			},
			"offsets": {
				"from": 601360,
				"to": 603660
			},
			"text": "选择推广的产品"
		},
		{
			"timestamps": {
				"from": "00:10:03,660",
				"to": "00:10:05,720"
			},
			"offsets": {
				"from": 603660,
				"to": 605720
			},
			"text": "都是非常有方向的"
		},
		{
			"timestamps": {
				"from": "00:10:06,480",
				"to": "00:10:12,120"
			},
			"offsets": {
				"from": 606480,
				"to": 612120
			},
			"text": "所以我们在做店铺的时候一定要知道我们要卖什么产品, 主推什么产品"
		},
		{
			"timestamps": {
				"from": "00:10:12,120",
				"to": "00:10:21,080"
			},
			"offsets": {
				"from": 612120,
				"to": 621080
			},
			"text": "特别是那些已经做了非常多类目的, 或者是非常多品种, 品类的那些店铺, 一定要注意"
		},
		{
			"timestamps": {
				"from": "00:10:21,080",
				"to": "00:10:23,640"
			},
			"offsets": {
				"from": 621080,
				"to": 623640
			},
			"text": "在你的自动车预算有限"
		},
		{
			"timestamps": {
				"from": "00:10:23,640",
				"to": "00:10:26,960"
			},
			"offsets": {
				"from": 623640,
				"to": 626960
			},
			"text": "一定要选择部分品类先切入"
		},
		{
			"timestamps": {
				"from": "00:10:26,960",
				"to": "00:10:32,340"
			},
			"offsets": {
				"from": 626960,
				"to": 632340
			},
			"text": "然后再通过这些品类的整体的一个爆款产品"
		},
		{
			"timestamps": {
				"from": "00:10:32,600",
				"to": "00:10:35,680"
			},
			"offsets": {
				"from": 632600,
				"to": 635680
			},
			"text": "优品, 实力品, 加上爆款"
		},
		{
			"timestamps": {
				"from": "00:10:35,680",
				"to": "00:10:37,980"
			},
			"offsets": {
				"from": 635680,
				"to": 637980
			},
			"text": "去带动你整个店铺的"
		},
		{
			"timestamps": {
				"from": "00:10:37,980",
				"to": "00:10:39,520"
			},
			"offsets": {
				"from": 637980,
				"to": 639520
			},
			"text": "其他品类的增长"
		},
		{
			"timestamps": {
				"from": "00:10:39,520",
				"to": "00:10:41,040"
			},
			"offsets": {
				"from": 639520,
				"to": 641040
			},
			"text": "因为有些"
		},
		{
			"timestamps": {
				"from": "00:10:41,040",
				"to": "00:10:42,580"
			},
			"offsets": {
				"from": 641040,
				"to": 642580
			},
			"text": "店铺是做一些"
		},
		{
			"timestamps": {
				"from": "00:10:42,580",
				"to": "00:10:44,640"
			},
			"offsets": {
				"from": 642580,
				"to": 644640
			},
			"text": "相关品类的,比如说"
		},
		{
			"timestamps": {
				"from": "00:10:44,640",
				"to": "00:10:45,660"
			},
			"offsets": {
				"from": 644640,
				"to": 645660
			},
			"text": "A买家"
		},
		{
			"timestamps": {
				"from": "00:10:45,660",
				"to": "00:10:46,940"
			},
			"offsets": {
				"from": 645660,
				"to": 646940
			},
			"text": "他既需要"
		},
		{
			"timestamps": {
				"from": "00:10:46,940",
				"to": "00:10:49,500"
			},
			"offsets": {
				"from": 646940,
				"to": 649500
			},
			"text": "C产品, B产品, 也需要"
		},
		{
			"timestamps": {
				"from": "00:10:49,500",
				"to": "00:10:50,520"
			},
			"offsets": {
				"from": 649500,
				"to": 650520
			},
			"text": "D产品"
		},
		{
			"timestamps": {
				"from": "00:10:50,520",
				"to": "00:10:52,060"
			},
			"offsets": {
				"from": 650520,
				"to": 652060
			},
			"text": "和F产品"
		},
		{
			"timestamps": {
				"from": "00:10:52,060",
				"to": "00:10:54,360"
			},
			"offsets": {
				"from": 652060,
				"to": 654360
			},
			"text": "那么我们前期可能只做"
		},
		{
			"timestamps": {
				"from": "00:10:54,360",
				"to": "00:10:58,460"
			},
			"offsets": {
				"from": 654360,
				"to": 658460
			},
			"text": "B跟B, 用直通车去拉升流量"
		},
		{
			"timestamps": {
				"from": "00:10:58,720",
				"to": "00:11:03,320"
			},
			"offsets": {
				"from": 658720,
				"to": 663320
			},
			"text": "那么只要这个B跟B能够给我们店铺引来A这类人"
		},
		{
			"timestamps": {
				"from": "00:11:03,320",
				"to": "00:11:07,420"
			},
			"offsets": {
				"from": 663320,
				"to": 667420
			},
			"text": "那么这类买家他也会对我们店铺里面DF产品"
		},
		{
			"timestamps": {
				"from": "00:11:07,420",
				"to": "00:11:09,220"
			},
			"offsets": {
				"from": 667420,
				"to": 669220
			},
			"text": "可能也会产生采购"
		},
		{
			"timestamps": {
				"from": "00:11:09,220",
				"to": "00:11:13,060"
			},
			"offsets": {
				"from": 669220,
				"to": 673060
			},
			"text": "所以我们是先从小去切入然后"
		},
		{
			"timestamps": {
				"from": "00:11:13,060",
				"to": "00:11:15,100"
			},
			"offsets": {
				"from": 673060,
				"to": 675100
			},
			"text": "把有限的资源用好"
		},
		{
			"timestamps": {
				"from": "00:11:15,100",
				"to": "00:11:17,920"
			},
			"offsets": {
				"from": 675100,
				"to": 677920
			},
			"text": "去拉升我们店铺的总的流量"
		},
		{
			"timestamps": {
				"from": "00:11:17,920",
				"to": "00:11:21,240"
			},
			"offsets": {
				"from": 677920,
				"to": 681240
			},
			"text": "然后再带动整个店铺的总的流量的增长"
		},
		{
			"timestamps": {
				"from": "00:11:21,240",
				"to": "00:11:24,840"
			},
			"offsets": {
				"from": 681240,
				"to": 684840
			},
			"text": "这就是为什么我们一定要明确我们的主推产品了"
		},
		{
			"timestamps": {
				"from": "00:11:25,860",
				"to": "00:11:31,740"
			},
			"offsets": {
				"from": 685860,
				"to": 691740
			},
			"text": "希望这节课能够让我们大家有一个核心主推产品的一个概念"
		},
		{
			"timestamps": {
				"from": "00:11:31,740",
				"to": "00:11:34,300"
			},
			"offsets": {
				"from": 691740,
				"to": 694300
			},
			"text": "这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:11:34,300",
				"to": "00:11:35,580"
			},
			"offsets": {
				"from": 694300,
				"to": 695580
			},
			"text": "下节课我们再见"
		}
	]
}
