				"to": 403800
			},
			"text": "第一条路径就是从我们店铺里面找相似的产品"
		},
		{
			"timestamps": {
				"from": "00:06:43,800",
				"to": "00:06:46,280"
			},
			"offsets": {
				"from": 403800,
				"to": 406280
			},
			"text": "数据比较好的去打造成爆品"
		},
		{
			"timestamps": {
				"from": "00:06:46,280",
				"to": "00:06:49,680"
			},
			"offsets": {
				"from": 406280,
				"to": 409680
			},
			"text": "第二个就是我们重新去找产品来发"
		},
		{
			"timestamps": {
				"from": "00:06:49,680",
				"to": "00:06:53,960"
			},
			"offsets": {
				"from": 409680,
				"to": 413960
			},
			"text": "重新从新品加速计划去推广来打造爆品"
		},
		{
			"timestamps": {
				"from": "00:06:53,960",
				"to": "00:06:56,440"
			},
			"offsets": {
				"from": 413960,
				"to": 416440
			},
			"text": "按照这两条路径去走就可以了"
		},
		{
			"timestamps": {
				"from": "00:06:56,440",
				"to": "00:07:01,760"
			},
			"offsets": {
				"from": 416440,
				"to": 421760
			},
			"text": "这个就是关于我们要找到目标国家访问和循环偏好"
		},
		{
			"timestamps": {
				"from": "00:07:01,760",
				"to": "00:07:03,280"
			},
			"offsets": {
				"from": 421760,
				"to": 423280
			},
			"text": "有交集的产品"
		},
		{
			"timestamps": {
				"from": "00:07:03,280",
				"to": "00:07:04,860"
			},
			"offsets": {
				"from": 423280,
				"to": 424860
			},
			"text": "一定要有交集的产品"
		},
		{
			"timestamps": {
				"from": "00:07:04,860",
				"to": "00:07:08,880"
			},
			"offsets": {
				"from": 424860,
				"to": 428880
			},
			"text": "因为有交集才代表着它是非常受市场欢迎的"
		},
		{
			"timestamps": {
				"from": "00:07:08,880",
				"to": "00:07:11,860"
			},
			"offsets": {
				"from": 428880,
				"to": 431860
			},
			"text": "而且已经被市场验证它是有需求的"
		},
		{
			"timestamps": {
				"from": "00:07:11,860",
				"to": "00:07:16,620"
			},
			"offsets": {
				"from": 431860,
				"to": 436620
			},
			"text": "再对这些有需求的产品进行打造爆品,就非常容易的成功了"
		},
		{
			"timestamps": {
				"from": "00:07:16,620",
				"to": "00:07:26,500"
			},
			"offsets": {
				"from": 436620,
				"to": 446500
			},
			"text": "这个就是关于我们在具体内幕,具体的国家下, 国家偏好这个内幕里面的哪一些款式的风格的产品"
		},
		{
			"timestamps": {
				"from": "00:07:26,500",
				"to": "00:07:37,160"
			},
			"offsets": {
				"from": 446500,
				"to": 457160
			},
			"text": "接下来就是到这个品类偏好, 也就是我们要掌握这个国家需求的品类和推广的资源, 倾斜到这些品类"
		},
		{
			"timestamps": {
				"from": "00:07:37,160",
				"to": "00:07:44,360"
			},
			"offsets": {
				"from": 457160,
				"to": 464360
			},
			"text": "比如说我们知道美国在这个品类下美国这个国家偏好的是更细维度的哪些品类"
		},
		{
			"timestamps": {
				"from": "00:07:44,360",
				"to": "00:07:49,960"
			},
			"offsets": {
				"from": 464360,
				"to": 469960
			},
			"text": "那么我们就可以倾斜我们的公车的资源或者是预算去推广这类产品"
		},
		{
			"timestamps": {
				"from": "00:07:49,960",
				"to": "00:07:53,920"
			},
			"offsets": {
				"from": 469960,
				"to": 473920
			},
			"text": "我们做店铺就是要找到市场偏好的品类"
		},
		{
			"timestamps": {
				"from": "00:07:53,920",
				"to": "00:08:02,040"
			},
			"offsets": {
				"from": 473920,
				"to": 482040
			},
			"text": "店铺在产品规划的时候和公车推广策略方面都要顺着这个市场的需求去推广"
		},
		{
			"timestamps": {
				"from": "00:08:02,040",
				"to": "00:08:03,600"
			},
			"offsets": {
				"from": 482040,
				"to": 483600
			},
			"text": "满足市场需求就行了"
		},
		{
			"timestamps": {
				"from": "00:08:03,600",
				"to": "00:08:10,740"
			},
			"offsets": {
				"from": 483600,
				"to": 490740
			},
			"text": "这里面有几个品类, 也就是美国它偏好的品类, 代表着它的一个流量的大小"
		},
		{
			"timestamps": {
				"from": "00:08:10,740",
				"to": "00:08:21,800"
			},
			"offsets": {
				"from": 490740,
				"to": 501800
			},
			"text": "那么通过品类的偏好, 知道当前这个国家需求哪些品类最为迫切, 以及现在这个国家重点品类切入的方向是哪些"
		},
		{
			"timestamps": {
				"from": "00:08:21,800",
				"to": "00:08:31,420"
			},
			"offsets": {
				"from": 501800,
				"to": 511420
			},
			"text": "有利于电部产品布局和直通的推广策略的一个制定, 在这些流量大的品类中倾斜更多的流量资源"
		},
		{
			"timestamps": {
				"from": "00:08:31,420",
				"to": "00:08:53,440"
			},
			"offsets": {
				"from": 511420,
				"to": 533440
			},
			"text": "比如说我们在这个类目下, 如果你看到的这些品类, 它跟这些发寻盘的品类有交集的时候, 那么你就可以快速的验证, 这个品类是非常受这个国家的偏好的, 所以说你在推广的时候, 或者是发产品的时候, 都应该集中资源去做这个品类优先"
		},
		{
			"timestamps": {
				"from": "00:08:53,440",
				"to": "00:08:59,260"
			},
			"offsets": {
				"from": 533440,
				"to": 539260
			},
			"text": "那么以上就是关于通过国家这个维度进行市场分析"
		},
		{
			"timestamps": {
				"from": "00:08:59,260",
				"to": "00:09:03,100"
			},
			"offsets": {
				"from": 539260,
				"to": 543100
			},
			"text": "那么接着我们到后台去看一下具体如何操作"
		},
		{
			"timestamps": {
				"from": "00:09:03,100",
				"to": "00:09:06,260"
			},
			"offsets": {
				"from": 543100,
				"to": 546260
			},
			"text": "首先我们打开的是第一个查国家"
		},
		{
			"timestamps": {
				"from": "00:09:06,260",
				"to": "00:09:07,960"
			},
			"offsets": {
				"from": 546260,
				"to": 547960
			},
			"text": "内幕你确定了吗"
		},
		{
			"timestamps": {
				"from": "00:09:07,960",
				"to": "00:09:11,380"
			},
			"offsets": {
				"from": 547960,
				"to": 551380
			},
			"text": "如果没有确定的话就按照这个先固定这个内幕"
		},
		{
			"timestamps": {
				"from": "00:09:11,380",
				"to": "00:09:14,300"
			},
			"offsets": {
				"from": 551380,
				"to": 554300
			},
			"text": "内幕固定了之后我们选择流量巨大的国家"
		},
		{
			"timestamps": {
				"from": "00:09:14,300",
				"to": "00:09:15,060"
			},
			"offsets": {
				"from": 554300,
				"to": 555060
			},
