			"timestamps": {
				"from": "00:09:22,940",
				"to": "00:09:24,940"
			},
			"offsets": {
				"from": 562940,
				"to": 564940
			},
			"text": "第四个就是直通车的数据分析"
		},
		{
			"timestamps": {
				"from": "00:09:24,940",
				"to": "00:09:26,940"
			},
			"offsets": {
				"from": 564940,
				"to": 566940
			},
			"text": "这里也是一样"
