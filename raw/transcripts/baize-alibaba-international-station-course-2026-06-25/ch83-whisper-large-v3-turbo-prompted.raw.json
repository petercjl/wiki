				"to": "00:09:18,940"
			},
			"offsets": {
				"from": 554940,
				"to": 558940
			},
			"text": "所以说这是一环扣一环"
		},
		{
			"timestamps": {
				"from": "00:09:18,940",
				"to": "00:09:22,940"
			},
			"offsets": {
				"from": 558940,
				"to": 562940
			},
			"text": "而且它们之间都是关联性的"
