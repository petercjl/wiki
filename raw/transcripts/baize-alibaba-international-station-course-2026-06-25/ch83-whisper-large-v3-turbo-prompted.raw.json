			"timestamps": {
				"from": "00:07:45,940",
				"to": "00:07:51,940"
			},
			"offsets": {
				"from": 465940,
				"to": 471940
			},
			"text": "但是呢现在变成了这里全部的直通这流量可能降到30%"
		},
		{
			"timestamps": {
				"from": "00:07:51,940",
				"to": "00:07:56,940"
			},
			"offsets": {
				"from": 471940,
				"to": 476940
			},
			"text": "那么这里的自然流量可能70%"
		},
		{
			"timestamps": {
				"from": "00:07:56,940",
				"to": "00:07:58,940"
			},
			"offsets": {
				"from": 476940,
				"to": 478940
			},
			"text": "很有可能这里自然流量下降"
