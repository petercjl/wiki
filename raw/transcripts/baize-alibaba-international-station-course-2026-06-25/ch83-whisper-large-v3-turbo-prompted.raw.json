			},
			"offsets": {
				"from": 540940,
				"to": 541940
			},
			"text": "单品变化"
		},
		{
			"timestamps": {
				"from": "00:09:01,940",
				"to": "00:09:03,940"
			},
			"offsets": {
				"from": 541940,
				"to": 543940
			},
			"text": "这是多个产品的变化"
		},
