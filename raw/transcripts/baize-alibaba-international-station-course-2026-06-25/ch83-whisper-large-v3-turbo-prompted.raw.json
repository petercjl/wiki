				"to": "00:09:36,940"
			},
			"offsets": {
				"from": 572940,
				"to": 576940
			},
			"text": "因为我们直通车的课程里面讲的非常的详细"
		},
		{
			"timestamps": {
				"from": "00:09:36,940",
				"to": "00:09:40,940"
			},
			"offsets": {
				"from": 576940,
				"to": 580940
			},
			"text": "第二个就是点击词是否发生变化"
		},
