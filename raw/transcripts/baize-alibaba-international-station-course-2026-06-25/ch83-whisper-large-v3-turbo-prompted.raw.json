			"timestamps": {
				"from": "00:10:55,940",
				"to": "00:10:59,940"
			},
			"offsets": {
				"from": 655940,
				"to": 659940
			},
			"text": "比如说你A产品本来的点击的都是"
		},
		{
			"timestamps": {
				"from": "00:10:59,940",
				"to": "00:11:03,940"
			},
			"offsets": {
				"from": 659940,
				"to": 663940
			},
			"text": "美国英国澳大利亚"
