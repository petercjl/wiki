				"to": "00:08:15,940"
			},
			"offsets": {
				"from": 493940,
				"to": 495940
			},
			"text": "但是你现在变成优品"
		},
		{
			"timestamps": {
				"from": "00:08:15,940",
				"to": "00:08:17,940"
			},
			"offsets": {
				"from": 495940,
				"to": 497940
			},
			"text": "甚至连优品都不是了"
		},
		{
			"timestamps": {
				"from": "00:08:17,940",
				"to": "00:08:18,940"
			},
			"offsets": {
				"from": 497940,
				"to": 498940
			},
			"text": "连优品都不是了"
		},
		{
			"timestamps": {
				"from": "00:08:18,940",
				"to": "00:08:21,940"
			},
			"offsets": {
				"from": 498940,
				"to": 501940
			},
			"text": "是不是自然流量就会出现暴跌"
