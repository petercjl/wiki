				"to": 230240
			},
			"text": "比如说你要选第二个就是英国, 那么你按照这个思路, 点击一下英国, 进入之后也是按照这个逻辑"
		},
		{
			"timestamps": {
				"from": "00:03:50,240",
				"to": "00:03:58,680"
			},
			"offsets": {
				"from": 230240,
				"to": 238680
			},
			"text": "或者是说你有更加精细的内幕的话, 你直接比如说我就做这个内幕了, 那么你也可以选择更细分的维度"
		},
		{
			"timestamps": {
				"from": "00:03:58,680",
				"to": "00:04:01,360"
			},
			"offsets": {
				"from": 238680,
				"to": 241360
			},
			"text": "那么下面的数据就会更加的准确"
		},
		{
			"timestamps": {
				"from": "00:04:01,360",
				"to": "00:04:10,080"
			},
			"offsets": {
				"from": 241360,
				"to": 250080
			},
			"text": "如果你觉得这里的关键词, 比如说这里的关键词太少, 找不到, 不够组合标题, 那么我们可以来买家参谋这里看"
		},
		{
			"timestamps": {
				"from": "00:04:10,080",
				"to": "00:04:20,260"
			},
			"offsets": {
				"from": 250080,
				"to": 260260
			},
			"text": "一定要选择更细分的维度去看, 订单买家, 选盘买家, 还有TM买家, 看时间维度长一点点, 往下拉, 你看这里不是有词吗"
		},
		{
			"timestamps": {
				"from": "00:04:20,260",
				"to": "00:04:28,240"
			},
			"offsets": {
				"from": 260260,
				"to": 268240
			},
			"text": "有行业买家偏好词, 还有买家全站的偏好词, 这些词, 你都可以把它整理出来, 然后去组合标题, 再去推广"
		},
		{
			"timestamps": {
				"from": "00:04:28,240",
				"to": "00:04:57,820"
			},
			"offsets": {
				"from": 268240,
				"to": 297820
			},
			"text": "其实这个思路还是比较简单的, 主要一个就去选品, 第二个就是你确定了推广国家, 然后再去选这些国家偏好的关键词, 再反过来去组合标题, 再去推广, 推广的时候你又把这些国家锁定词, 也锁定所有的资源都集中在比较精准的一个范围内去做一个推广, 成功概率会相对来说比较大, 当然有可能就是你组标题的时候做的不好, 或者是说你选款的时候选的不好,"
		},
		{
			"timestamps": {
				"from": "00:04:58,240",
				"to": "00:05:02,540"
			},
			"offsets": {
				"from": 298240,
				"to": 302540
			},
			"text": "也会导致你这个计划可能没有测试得出有潜力的链接"
		},
		{
			"timestamps": {
				"from": "00:05:02,540",
				"to": "00:05:07,120"
			},
			"offsets": {
				"from": 302540,
				"to": 307120
			},
			"text": "所以我们要结合我们之前学习过的主标题的方法"
		},
		{
			"timestamps": {
				"from": "00:05:07,120",
				"to": "00:05:12,680"
			},
			"offsets": {
				"from": 307120,
				"to": 312680
			},
			"text": "加上之前我们选品的一些方法, 选国家的一方法"
		},
		{
			"timestamps": {
				"from": "00:05:12,680",
				"to": "00:05:15,920"
			},
			"offsets": {
				"from": 312680,
				"to": 315920
			},
			"text": "你可以按照这个思路去征合的应用"
		},
		{
			"timestamps": {
				"from": "00:05:15,920",
				"to": "00:05:20,200"
			},
			"offsets": {
				"from": 315920,
				"to": 320200
			},
			"text": "也就是你不要局限在只在这个市场参谋里面去选择"
		},
		{
			"timestamps": {
				"from": "00:05:20,200",
				"to": "00:05:25,380"
			},
			"offsets": {
				"from": 320200,
				"to": 325380
			},
			"text": "我们还有其他的维度,比如说行业的榜单, 买家参谋, 流量参谋等等"
		},
		{
			"timestamps": {
				"from": "00:05:25,380",
				"to": "00:05:55,280"
			},
			"offsets": {
				"from": 325380,
				"to": 355280
			},
			"text": "这些维度去综合的去选择, 最后进行对比之后, 再确定我们要选哪些品类, 哪些词, 哪些国家, 再去做推广, 就可以了, 推广的过程中, 如果有数据了, 比如说有寻盘TM了, 你一定要记得去补充一些订单, 因为没有订单, 它就不能形成一个有效的流量闭环, 因为流量闭环是流量到寻盘到TM, 再到订单, 订单再反过来就会给这个产品,"
		},
		{
			"timestamps": {
				"from": "00:05:55,380",
				"to": "00:05:59,740"
			},
			"offsets": {
				"from": 355380,
				"to": 359740
			},
			"text": "增加一个权重, 来提升你这个产品的排名"
		},
		{
			"timestamps": {
				"from": "00:05:59,740",
				"to": "00:06:03,580"
			},
			"offsets": {
				"from": 359740,
				"to": 363580
			},
			"text": "产品排名提升了是不是它的流量就会更多"
		},
		{
			"timestamps": {
				"from": "00:06:03,580",
				"to": "00:06:08,180"
			},
			"offsets": {
				"from": 363580,
				"to": 368180
			},
			"text": "流量多了是不是它的寻盘会更多, 寻盘多了是不是可能订单就会更多"
		},
		{
			"timestamps": {
				"from": "00:06:08,180",
				"to": "00:06:10,240"
			},
			"offsets": {
				"from": 368180,
				"to": 370240
			},
			"text": "这就是完整的一个闭环"
		},
		{
			"timestamps": {
				"from": "00:06:10,240",
				"to": "00:06:15,220"
			},
			"offsets": {
				"from": 370240,
				"to": 375220
			},
			"text": "所以很多时候我们推广到一定的程度都是有寻盘跟贴母"
		},
		{
			"timestamps": {
				"from": "00:06:15,220",
				"to": "00:06:18,540"
			},
			"offsets": {
				"from": 375220,
				"to": 378540
			},
			"text": "我们如果本身线下有比较多的订单"
		},
		{
			"timestamps": {
				"from": "00:06:18,540",
				"to": "00:06:20,880"
			},
			"offsets": {
				"from": 378540,
				"to": 380880
			},
			"text": "或者是我们也有一些老客户"
		},
		{
			"timestamps": {
				"from": "00:06:20,880",
				"to": "00:06:25,080"
			},
			"offsets": {
				"from": 380880,
				"to": 385080
			},
			"text": "我们看看能不能把一些线下的订单来绑定一下"
		},
		{
			"timestamps": {
				"from": "00:06:25,080",
				"to": "00:06:30,300"
			},
			"offsets": {
				"from": 385080,
				"to": 390300
			},
			"text": "我们现在正在推广的这些产品让它形成一个有效的数据闭环"
		},
		{
			"timestamps": {
				"from": "00:06:30,300",
				"to": "00:06:36,320"
			},
			"offsets": {
				"from": 390300,
				"to": 396320
			},
			"text": "这样对我们店铺的整体的一个爆款打造是非常非常重要的"
		},
		{
			"timestamps": {
				"from": "00:06:36,320",
				"to": "00:06:39,020"
			},
			"offsets": {
				"from": 396320,
				"to": 399020
			},
			"text": "这个环节被很多人忽视"
		},
		{
			"timestamps": {
				"from": "00:06:39,020",
				"to": "00:06:44,720"
			},
			"offsets": {
				"from": 399020,
				"to": 404720
			},
			"text": "所以你在打造爆款的时候一定要注重寻盘到订单转化的这个环节"
		},
		{
			"timestamps": {
				"from": "00:06:44,720",
				"to": "00:06:50,580"
			},
			"offsets": {
				"from": 404720,
				"to": 410580
			},
			"text": "因为缺少了这个环节很多产品都是有很多寻盘变成了寻盘量很少"
		},
		{
			"timestamps": {
				"from": "00:06:50,580",
				"to": "00:06:52,680"
			},
			"offsets": {
				"from": 410580,
				"to": 412680
			},
			"text": "最后面就这个产品流量也少了"
		},
		{
			"timestamps": {
				"from": "00:06:52,680",
				"to": "00:06:55,340"
			},
			"offsets": {
				"from": 412680,
				"to": 415340
			},
			"text": "最终就导致这个产品变成了一个普通的产品"
		},
		{
			"timestamps": {
				"from": "00:06:55,340",
				"to": "00:06:57,400"
			},
			"offsets": {
				"from": 415340,
				"to": 417400
			},
			"text": "所以这个一定要重视起来"
		},
		{
			"timestamps": {
				"from": "00:06:57,400",
				"to": "00:07:00,380"
			},
			"offsets": {
				"from": 417400,
				"to": 420380
			},
			"text": "我相信这个能够帮你更快的去打造爆品"
		},
		{
			"timestamps": {
				"from": "00:07:00,380",
				"to": "00:07:02,300"
			},
			"offsets": {
				"from": 420380,
				"to": 422300
			},
			"text": "这节课我们就先讲到这里"
		},
		{
			"timestamps": {
				"from": "00:07:02,300",
				"to": "00:07:03,600"
			},
			"offsets": {
				"from": 422300,
				"to": 423600
			},
			"text": "下节课我们再见"
		}
	]
}
